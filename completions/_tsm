#compdef tsm
# zsh completion for tsm

_tsm_sessions() {
  local sessions
  sessions=(${(f)"$(tmux list-sessions -F '#{session_name}' 2>/dev/null)"})
  _describe 'session' sessions
}

_tsm_saved_configs() {
  local dir="${XDG_CONFIG_HOME:-$HOME/.config}/tsm/sessions"
  local configs
  configs=(${(f)"$(find "$dir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null | sed 's|.*/||; s|\.yaml$||')"})
  _describe 'saved config' configs
}

_tsm_user_templates() {
  local dir="${XDG_CONFIG_HOME:-$HOME/.config}/tsm/templates"
  local templates
  templates=(${(f)"$(find "$dir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null | sed 's|.*/||; s|\.yaml$||')"})
  _describe 'user template' templates
}

_tsm_template() {
  local state
  _arguments \
    '1: :->action' \
    '*: :->args'
  case $state in
    action)
      local actions
      actions=(
        'list:list all templates'
        'apply:create a new session from a template'
        'save:save current session layout as a template'
        'delete:delete a user template'
        'help:show template help'
      )
      _describe 'action' actions
      ;;
    args)
      case $words[2] in
        apply)
          local builtins
          builtins=(
            'builtin/simple:1 window, 1 pane'
            'builtin/split-h:1 window, 2 panes left/right'
            'builtin/split-v:1 window, 2 panes top/bottom'
            'builtin/main-h:1 window, 3 panes (2 top + 1 bottom)'
            'builtin/main-v:1 window, 3 panes (1 left + 2 right)'
          )
          _describe 'built-in template' builtins
          _tsm_user_templates
          ;;
        delete)
          _tsm_user_templates
          ;;
      esac
      ;;
  esac
}

_tsm_log() {
  local state
  _arguments \
    '1: :->action' \
    '*: :->args'
  case $state in
    action)
      local actions
      actions=(
        'start:start logging pane output'
        'stop:stop logging'
        'status:show panes being logged'
        'list:list log files'
        'show:view log via pager'
        'tail:follow log in real time'
        'grep:search within log file'
        'clean:delete log files'
        'help:show log help'
      )
      _describe 'action' actions
      ;;
    args)
      case $words[2] in
        start)     _arguments '--timestamp[prepend timestamps]' '--all[all panes in session]' ;;
        show|tail|grep) _arguments '--plain[strip ANSI escapes]' ;;
        clean)     _arguments '--all[clean all sessions]' ;;
      esac
      ;;
  esac
}

_tsm() {
  local state

  _arguments \
    '1: :->subcommand' \
    '*: :->args'

  case $state in
    subcommand)
      local subcommands
      subcommands=(
        'new:create and attach a new session'
        'ls:list all sessions'
        'kill:kill a session'
        'rename:rename a session'
        'config:read/edit/reload tmux config'
        'save:save session layout'
        'restore:restore a saved session'
        'log:pane output logging'
        'template:manage session templates'
        'version:show version'
        'help:show help'
      )
      _describe 'subcommand' subcommands
      ;;
    args)
      case $words[2] in
        kill)
          _arguments '--all[multi-select kill]'
          _tsm_sessions
          ;;
        rename)
          _tsm_sessions
          ;;
        config)
          _arguments \
            '--read[read tmux config (default)]' \
            '--edit[edit tmux config]' \
            '--reload[reload tmux config]' \
            '--tsm[edit tsm config]'
          ;;
        save)
          _arguments \
            '--list[list saved configs]' \
            '--delete[delete a saved config]'
          _tsm_sessions
          ;;
        restore)
          _arguments '--with-commands[re-run saved commands]'
          _tsm_saved_configs
          ;;
        log)
          _tsm_log
          ;;
        template)
          _tsm_template
          ;;
      esac
      ;;
  esac
}

_tsm "$@"
