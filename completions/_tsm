#compdef tsm
# zsh completion for tsm

_tsm_sessions() {
  local sessions
  sessions=(${(f)"$(tmux list-sessions -F '#{session_name}' 2>/dev/null)"})
  _describe 'session' sessions
}

_tsm() {
  local state

  _arguments \
    '1: :->subcommand' \
    '*: :->args'

  case $state in
    subcommand)
      local subcommands
      subcommands=(
        'new:create and attach a new session'
        'ls:list all sessions'
        'kill:kill a session by name'
        'version:show version'
        'help:show help'
      )
      _describe 'subcommand' subcommands
      ;;
    args)
      case $words[2] in
        kill) _tsm_sessions ;;
      esac
      ;;
  esac
}

_tsm "$@"
