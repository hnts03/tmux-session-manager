#!/usr/bin/env bash
# tsm - tmux session manager
# A lightweight fzf-based tmux session manager
# https://github.com/hnts03/tmux-session-manager

set -euo pipefail

VERSION="0.3.0"

# ─── config defaults (overridden by config file, then env vars) ──────────────

_TSM_SESSIONS_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tsm/sessions"
_TSM_LOGS_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tsm/logs"
_TSM_LOG_MAX_BYTES=10485760
_TSM_RESTORE_SKIP_COMMANDS=(bash zsh sh fish dash tmux)

# ─── dependency check ────────────────────────────────────────────────────────

check_deps() {
  local missing=()
  command -v tmux &>/dev/null || missing+=("tmux")
  command -v fzf  &>/dev/null || missing+=("fzf")
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "tsm: missing required dependencies: ${missing[*]}" >&2
    echo "Install them and try again." >&2
    exit 1
  fi
}

require_yq() {
  if ! command -v yq &>/dev/null; then
    echo "tsm: 'yq' is required for save/restore. Install with: brew install yq" >&2
    exit 1
  fi
}

sessions_dir()       { echo "$_TSM_SESSIONS_DIR"; }
logs_dir()           { echo "$_TSM_LOGS_DIR"; }
tsm_self_config_path() { echo "${XDG_CONFIG_HOME:-$HOME/.config}/tsm/config.yaml"; }

# Sanitize a session name for use as a config filename (replace / with _)
config_name_for() { printf '%s' "${1//\//_}"; }

load_config() {
  local config_file
  config_file="$(tsm_self_config_path)"
  [[ ! -f "$config_file" ]] && return 0
  if ! command -v yq &>/dev/null; then
    echo "tsm: config file found at $config_file but 'yq' is required to read it." >&2
    echo "     Install with: brew install yq  (falling back to defaults)" >&2
    return 0
  fi
  local val skip_count
  val=$(yq -r '.sessions_dir // ""' "$config_file" 2>/dev/null)
  [[ -n "$val" ]] && _TSM_SESSIONS_DIR="${val/#\~/$HOME}"
  val=$(yq -r '.logs_dir // ""' "$config_file" 2>/dev/null)
  [[ -n "$val" ]] && _TSM_LOGS_DIR="${val/#\~/$HOME}"
  val=$(yq -r '.log_max_bytes // ""' "$config_file" 2>/dev/null)
  [[ -n "$val" ]] && _TSM_LOG_MAX_BYTES="$val"
  skip_count=$(yq -r '(.restore_skip_commands // []) | length' "$config_file" 2>/dev/null)
  if [[ "${skip_count:-0}" -gt 0 ]]; then
    _TSM_RESTORE_SKIP_COMMANDS=()
    while IFS= read -r cmd; do
      _TSM_RESTORE_SKIP_COMMANDS+=("$cmd")
    done < <(yq -r '.restore_skip_commands[]' "$config_file")
  fi
}

apply_env_overrides() {
  [[ -n "${TSM_LOG_MAX_BYTES:-}" ]] && _TSM_LOG_MAX_BYTES="$TSM_LOG_MAX_BYTES"
  [[ -n "${TSM_SESSIONS_DIR:-}"  ]] && _TSM_SESSIONS_DIR="$TSM_SESSIONS_DIR"
  [[ -n "${TSM_LOGS_DIR:-}"      ]] && _TSM_LOGS_DIR="$TSM_LOGS_DIR"
}

# resolve a target to absolute pane id; default = current pane
resolve_pane_target() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    if ! in_tmux; then
      echo "tsm log: must be inside tmux or specify a target." >&2
      return 1
    fi
    target=$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}')
  fi
  echo "$target"
}

# convert "session:window.pane" target to a log file path
log_file_for() {
  local target="$1"
  local session window pane
  session=$(tmux display-message -t "$target" -p '#{session_name}' 2>/dev/null) || return 1
  window=$(tmux display-message  -t "$target" -p '#{window_index}' 2>/dev/null) || return 1
  pane=$(tmux display-message    -t "$target" -p '#{pane_index}' 2>/dev/null) || return 1
  echo "$(logs_dir)/$session/$window.$pane.log"
}

# ─── helpers ─────────────────────────────────────────────────────────────────

in_tmux()      { [[ -n "${TMUX:-}" ]]; }
current_session() { tmux display-message -p '#S' 2>/dev/null; }

# ─── actions ─────────────────────────────────────────────────────────────────

do_attach() {
  local session="$1"
  if in_tmux; then
    tmux switch-client -t "$session"
  else
    tmux attach-session -t "$session"
  fi
}

do_new() {
  printf "Enter new session name: "
  read -r new_name
  if [[ -z "$new_name" ]]; then
    echo "No name entered. Aborted."
    sleep 0.4
    main
    return
  fi
  if tmux has-session -t "$new_name" 2>/dev/null; then
    printf "Session '%s' already exists. Attach to it? [Y/n] " "$new_name"
    read -r confirm
    if [[ ! "$confirm" =~ ^[nN]$ ]]; then
      do_attach "$new_name"
    else
      sleep 0.4
      main
    fi
    return
  fi
  if in_tmux; then
    tmux new-session -d -s "$new_name"
    tmux switch-client -t "$new_name"
  else
    tmux new-session -s "$new_name"
  fi
}

do_delete() {
  local session="$1"
  if in_tmux && [[ "$session" == "$(current_session)" ]]; then
    echo "Cannot delete the currently attached session '$session'." >&2
    sleep 1
    main
    return
  fi
  printf "Delete session '%s'? [y/N] " "$session"
  read -r confirm
  if [[ "$confirm" =~ ^[yY]$ ]]; then
    tmux kill-session -t "$session"
    echo "Deleted session: $session"
  else
    echo "Cancelled."
  fi
  sleep 0.4
  main
}

do_detach() {
  if in_tmux; then
    tmux detach-client
  else
    echo "Not inside a tmux session." >&2
    sleep 1
  fi
}

do_rename() {
  local old_name="$1"
  printf "New name for '%s': " "$old_name"
  read -r new_name
  if [[ -z "$new_name" ]]; then
    echo "No name entered. Aborted."
    sleep 0.4
    main
    return
  fi
  tmux rename-session -t "$old_name" "$new_name" && echo "Renamed '$old_name' → '$new_name'"
  sleep 0.4
  main
}

do_kill() {
  local session="$1"
  if in_tmux && [[ "$session" == "$(current_session)" ]]; then
    echo "tsm: cannot kill the currently attached session '$session'." >&2
    exit 1
  fi
  tmux kill-session -t "$session" && echo "Killed session: $session"
}

pick_kill() {
  local session
  session=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | \
    fzf --ansi --reverse --no-sort --prompt="kill session > ") || return 0
  [[ -z "$session" ]] && return 0
  do_kill "$session"
}

pick_kill_multi() {
  local sessions
  sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | \
    fzf --ansi --reverse --no-sort --multi --prompt="kill sessions (TAB to select) > ") || return 0
  [[ -z "$sessions" ]] && return 0
  while read -r session; do
    if in_tmux && [[ "$session" == "$(current_session)" ]]; then
      echo "tsm: skipping current session '$session'" >&2
      continue
    fi
    tmux kill-session -t "$session" && echo "Killed session: $session"
  done <<< "$sessions"
}

tmux_config_path() {
  if [[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf" ]]; then
    echo "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"
  else
    echo "$HOME/.tmux.conf"
  fi
}

do_config_read() {
  local config
  config="$(tmux_config_path)"
  if [[ ! -f "$config" ]]; then
    echo "tsm: no tmux config found at $config" >&2
    exit 1
  fi
  local editor="${VISUAL:-${EDITOR:-vi}}"
  case "$(basename "$editor")" in
    vi|vim|nvim) "$editor" -R "$config" ;;
    nano)        "$editor" -v "$config" ;;
    *)           "$editor" "$config" ;;
  esac
}

do_config_reload() {
  if ! in_tmux; then
    echo "tsm: must be inside a tmux session to reload config." >&2
    exit 1
  fi
  local config
  config="$(tmux_config_path)"
  tmux source-file "$config" && echo "Reloaded: $config"
}

do_config_edit() {
  local config
  config="$(tmux_config_path)"
  local editor="${VISUAL:-${EDITOR:-vi}}"
  "$editor" "$config"
  printf "Reload tmux config now? [y/N] "
  read -r confirm
  if [[ "$confirm" =~ ^[yY]$ ]]; then
    do_config_reload
  fi
}

do_config_tsm() {
  local config_file
  config_file="$(tsm_self_config_path)"
  if [[ ! -f "$config_file" ]]; then
    mkdir -p "$(dirname "$config_file")"
    cat > "$config_file" <<'EOF'
# tsm configuration — uncomment and edit values to override defaults.
# log_max_bytes: 10485760          # 10 MB
# sessions_dir: ~/.config/tsm/sessions
# logs_dir: ~/.local/share/tsm/logs
# restore_skip_commands:
#   - bash
#   - zsh
#   - sh
#   - fish
#   - dash
#   - tmux
EOF
    echo "Created: $config_file"
  fi
  local editor="${VISUAL:-${EDITOR:-vi}}"
  "$editor" "$config_file"
}

# ─── save / restore ──────────────────────────────────────────────────────────

# YAML-safe single-quoted string: '' is the single-quote escape inside single quotes
yaml_squote() {
  local s="$1"
  printf "'%s'" "${s//\'/\'\'}"
}

bool_from_flag() {
  [[ "$1" == "1" ]] && echo "true" || echo "false"
}

is_skip_command() {
  local cmd="$1" skip
  for skip in "${_TSM_RESTORE_SKIP_COMMANDS[@]}"; do
    [[ "$cmd" == "$skip" ]] && return 0
  done
  return 1
}

pick_config() {
  local dir
  dir="$(sessions_dir)"
  if [[ ! -d "$dir" ]]; then
    echo "tsm restore: no saved configs (directory $dir does not exist)." >&2
    return 1
  fi
  local configs
  configs=$(find "$dir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null \
    | sed -e 's|.*/||' -e 's|\.yaml$||')
  if [[ -z "$configs" ]]; then
    echo "tsm restore: no saved configs in $dir." >&2
    return 1
  fi
  local picked
  picked=$(echo "$configs" | fzf --ansi --reverse --no-sort \
    --prompt="restore session > ") || return 1
  [[ -z "$picked" ]] && return 1
  echo "$picked"
}

do_restore() {
  local with_commands=false
  local name=""

  for arg in "$@"; do
    case "$arg" in
      --with-commands) with_commands=true ;;
      *) [[ -z "$name" ]] && name="$arg" ;;
    esac
  done

  if [[ -z "$name" ]]; then
    name="$(pick_config)" || return 0
  fi

  local file
  file="$(sessions_dir)/$(config_name_for "$name").yaml"
  if [[ ! -f "$file" ]]; then
    echo "tsm restore: config not found: $file" >&2
    exit 1
  fi

  require_yq

  local session
  session=$(yq -r '.name' "$file")

  if tmux has-session -t "$session" 2>/dev/null; then
    echo "tsm restore: session '$session' already exists." >&2
    echo "Overwrite is not yet supported — kill it first or rename the config." >&2
    exit 1
  fi

  local windows_data
  windows_data=$(yq -r '.windows | to_entries[] | "\(.key)|\(.value.name)|\(.value.layout)|\(.value.active)"' "$file")

  local first=true
  local active_window=""

  while IFS='|' read -r wi w_name w_layout w_active; do
    local n_panes first_cwd
    n_panes=$(yq -r ".windows[$wi].panes | length" "$file")
    first_cwd=$(yq -r ".windows[$wi].panes[0].cwd" "$file")

    if $first; then
      tmux new-session -d -s "$session" -n "$w_name" -c "$first_cwd"
      first=false
    else
      tmux new-window -t "$session" -n "$w_name" -c "$first_cwd"
    fi

    local current_idx first_pane_idx
    current_idx=$(tmux display-message -t "$session:" -p '#{window_index}')
    first_pane_idx=$(tmux display-message -t "$session:$current_idx" -p '#{pane_index}')

    local pane_targets=("$session:$current_idx.$first_pane_idx")

    local pi
    for ((pi=1; pi<n_panes; pi++)); do
      local p_cwd
      p_cwd=$(yq -r ".windows[$wi].panes[$pi].cwd" "$file")
      tmux split-window -t "$session:$current_idx" -c "$p_cwd"
      local new_pane_idx
      new_pane_idx=$(tmux display-message -t "$session:$current_idx" -p '#{pane_index}')
      pane_targets+=("$session:$current_idx.$new_pane_idx")
    done

    tmux select-layout -t "$session:$current_idx" "$w_layout" 2>/dev/null \
      || echo "tsm restore: warning — failed to apply layout for window '$w_name'" >&2

    if $with_commands; then
      for ((pi=0; pi<n_panes; pi++)); do
        local p_cmd
        p_cmd=$(yq -r ".windows[$wi].panes[$pi].command" "$file")
        if [[ -n "$p_cmd" ]] && ! is_skip_command "$p_cmd"; then
          tmux send-keys -t "${pane_targets[$pi]}" "$p_cmd" Enter
        fi
      done
    fi

    [[ "$w_active" == "true" ]] && active_window="$current_idx"
  done <<< "$windows_data"

  [[ -n "$active_window" ]] && tmux select-window -t "$session:$active_window"

  echo "Restored: $session"
  if in_tmux; then
    tmux switch-client -t "$session"
  else
    tmux attach-session -t "$session"
  fi
}

# ─── pane output logging ─────────────────────────────────────────────────────

# internal: read stdin, append to file with size cap + rotation
# Usage (called by tmux pipe-pane): tsm log __write <file> <max_bytes>
do_log_write() {
  local file="$1"
  local max="${2:-10485760}"
  mkdir -p "$(dirname "$file")"
  awk -v file="$file" -v max="$max" '
    BEGIN {
      cmd = "wc -c < \"" file "\" 2>/dev/null"
      cmd | getline written
      close(cmd)
      written = written + 0
    }
    {
      print >> file
      fflush(file)
      written += length($0) + 1
      if (written >= max) {
        close(file)
        system("mv \"" file "\" \"" file ".1\" 2>/dev/null")
        written = 0
      }
    }
  '
}

_panes_for_target() {
  # expand a target into list of session:window.pane
  local arg="$1"
  if [[ "$arg" == "--all" ]]; then
    in_tmux || { echo "tsm log: --all requires being inside tmux." >&2; return 1; }
    local session
    session=$(current_session)
    tmux list-panes -s -t "$session" \
      -F '#{session_name}:#{window_index}.#{pane_index}'
  else
    resolve_pane_target "$arg" || return 1
  fi
}

do_log_start() {
  local arg="${1:-}"
  local self="${TSM_SELF:-$0}"
  local max="${TSM_LOG_MAX_BYTES:-$_TSM_LOG_MAX_BYTES}"

  local self_q
  printf -v self_q '%q' "$self"

  local panes
  panes=$(_panes_for_target "$arg") || exit 1

  while read -r p; do
    [[ -z "$p" ]] && continue
    local file
    file=$(log_file_for "$p") || continue
    mkdir -p "$(dirname "$file")"
    local file_q
    printf -v file_q '%q' "$file"
    # close any existing pipe first to avoid double-piping
    tmux pipe-pane -t "$p"
    tmux pipe-pane -t "$p" "$self_q log __write $file_q $max"
    echo "Logging: $p → $file"
  done <<< "$panes"
}

do_log_stop() {
  local arg="${1:-}"
  local panes
  panes=$(_panes_for_target "$arg") || exit 1
  while read -r p; do
    [[ -z "$p" ]] && continue
    tmux pipe-pane -t "$p"
    echo "Stopped: $p"
  done <<< "$panes"
}

do_log_status() {
  local format='#{session_name}:#{window_index}.#{pane_index}|#{pane_pipe}'
  local any=false
  while IFS='|' read -r target piped; do
    if [[ "$piped" == "1" ]]; then
      local file
      file=$(log_file_for "$target")
      local size="-"
      [[ -f "$file" ]] && size=$(wc -c < "$file" 2>/dev/null | tr -d ' ')
      printf "  %-30s %10s bytes  %s\n" "$target" "$size" "$file"
      any=true
    fi
  done < <(tmux list-panes -a -F "$format" 2>/dev/null)
  $any || echo "No panes are being logged."
}

do_log_list() {
  local session="${1:-}"
  local dir
  dir=$(logs_dir)
  if [[ -n "$session" ]]; then
    dir="$dir/$session"
  fi
  if [[ ! -d "$dir" ]]; then
    echo "No log files in $dir"
    return 0
  fi
  find "$dir" -type f \( -name '*.log' -o -name '*.log.1' \) | sort | while read -r f; do
    local size
    size=$(wc -c < "$f" 2>/dev/null | tr -d ' ')
    printf "  %10s bytes  %s\n" "$size" "$f"
  done
}

do_log_show() {
  local target="" plain=false
  for a in "$@"; do
    case "$a" in
      --plain) plain=true ;;
      *)       [[ -z "$target" ]] && target="$a" ;;
    esac
  done

  local resolved
  resolved=$(resolve_pane_target "$target") || exit 1
  local file
  file=$(log_file_for "$resolved") || exit 1
  if [[ ! -f "$file" ]]; then
    echo "tsm log show: no log file for $resolved ($file)" >&2
    exit 1
  fi
  local pager="${PAGER:-less -R}"
  if $plain; then
    sed -E $'s/\x1b\\[[0-9;?]*[a-zA-Z]//g; s/\x1b\\][^\x07]*\x07//g' "$file" | $pager
  else
    $pager "$file"
  fi
}

do_log_tail() {
  local target="" plain=false
  for a in "$@"; do
    case "$a" in
      --plain) plain=true ;;
      *)       [[ -z "$target" ]] && target="$a" ;;
    esac
  done

  local resolved
  resolved=$(resolve_pane_target "$target") || exit 1
  local file
  file=$(log_file_for "$resolved") || exit 1
  if [[ ! -f "$file" ]]; then
    echo "tsm log tail: no log file for $resolved ($file)" >&2
    exit 1
  fi
  if $plain; then
    tail -F "$file" | sed -E $'s/\x1b\\[[0-9;?]*[a-zA-Z]//g; s/\x1b\\][^\x07]*\x07//g'
  else
    tail -F "$file"
  fi
}

do_log_clean() {
  local arg="${1:-}"
  local dir
  dir=$(logs_dir)
  case "$arg" in
    --all)
      [[ -d "$dir" ]] && rm -rf "$dir"/*.log "$dir"/*.log.1 "$dir"/*/*.log "$dir"/*/*.log.1 2>/dev/null
      echo "Cleaned all logs under $dir"
      ;;
    "")
      in_tmux || { echo "tsm log clean: specify a session or use --all." >&2; exit 1; }
      local session
      session=$(current_session)
      rm -rf "$dir/$session"
      echo "Cleaned: $dir/$session"
      ;;
    *)
      rm -rf "$dir/$arg"
      echo "Cleaned: $dir/$arg"
      ;;
  esac
}

do_save_list() {
  local dir
  dir="$(sessions_dir)"
  if [[ ! -d "$dir" ]]; then
    echo "No saved configs."
    return 0
  fi
  local has_yq=false
  command -v yq &>/dev/null && has_yq=true
  local any=false
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    local name session_name created windows panes running
    name=$(basename "$file" .yaml)
    if $has_yq; then
      session_name=$(yq -r '.name // ""' "$file" 2>/dev/null)
      [[ -z "$session_name" ]] && session_name="$name"
      created=$(yq -r '.created_at // "unknown"' "$file" 2>/dev/null)
      windows=$(yq -r '.windows | length' "$file" 2>/dev/null)
      panes=$(yq -r '[.windows[].panes | length] | add // 0' "$file" 2>/dev/null)
    else
      session_name="$name"
    fi
    running=""
    tmux has-session -t "$session_name" 2>/dev/null && running=" ●"
    if $has_yq; then
      printf "  %-20s  %s  (%s window(s), %s pane(s))%s\n" "$name" "$created" "$windows" "$panes" "$running"
    else
      printf "  %s%s\n" "$name" "$running"
    fi
    any=true
  done < <(find "$dir" -maxdepth 1 -name '*.yaml' -type f | sort)
  $any || echo "No saved configs."
}

do_save_delete() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    local dir
    dir="$(sessions_dir)"
    local configs
    configs=$(find "$dir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null \
      | sed -e 's|.*/||' -e 's|\.yaml$||')
    if [[ -z "$configs" ]]; then
      echo "tsm save: no saved configs to delete." >&2; return 1
    fi
    name=$(echo "$configs" | fzf --ansi --reverse --no-sort \
      --prompt="delete saved config > ") || return 0
    [[ -z "$name" ]] && return 0
  fi
  local file
  file="$(sessions_dir)/$(config_name_for "$name").yaml"
  if [[ ! -f "$file" ]]; then
    echo "tsm save: config not found: $file" >&2; exit 1
  fi
  printf "Delete saved config '%s'? [y/N] " "$name"
  read -r confirm
  if [[ "$confirm" =~ ^[yY]$ ]]; then
    rm "$file" && echo "Deleted: $file"
  else
    echo "Cancelled."
  fi
}

do_save() {
  local target="${1:-}"

  if [[ -z "$target" ]]; then
    if ! in_tmux; then
      echo "tsm save: must be inside tmux or pass a session name." >&2
      return 1
    fi
    target="$(current_session)"
  fi

  if ! tmux has-session -t "$target" 2>/dev/null; then
    echo "tsm save: session '$target' not found." >&2
    return 1
  fi

  local dir
  dir="$(sessions_dir)"
  mkdir -p "$dir"
  local out="$dir/$(config_name_for "$target").yaml"

  if [[ -f "$out" ]]; then
    local stored_name=""
    command -v yq &>/dev/null && stored_name=$(yq -r '.name // ""' "$out" 2>/dev/null)
    if [[ -n "$stored_name" && "$stored_name" != "$target" ]]; then
      printf "Config '%s' belongs to session '%s'. Overwrite with '%s'? [y/N] " \
        "$(basename "$out" .yaml)" "$stored_name" "$target"
    else
      printf "Config '%s' already exists. Overwrite? [y/N] " "$(basename "$out" .yaml)"
    fi
    read -r confirm
    [[ ! "$confirm" =~ ^[yY]$ ]] && { echo "Cancelled."; return 0; }
  fi

  {
    printf "name: %s\n" "$(yaml_squote "$target")"
    printf "created_at: %s\n" "$(yaml_squote "$(date -u +%Y-%m-%dT%H:%M:%SZ)")"
    printf "windows:\n"

    local windows
    windows=$(tmux list-windows -t "$target" \
      -F '#{window_index}|#{window_name}|#{window_active}|#{window_layout}')

    while IFS='|' read -r w_idx w_name w_active w_layout; do
      printf "  - index: %s\n" "$w_idx"
      printf "    name: %s\n" "$(yaml_squote "$w_name")"
      printf "    active: %s\n" "$(bool_from_flag "$w_active")"
      printf "    layout: %s\n" "$(yaml_squote "$w_layout")"
      printf "    panes:\n"

      local panes
      panes=$(tmux list-panes -t "$target:$w_idx" \
        -F '#{pane_index}|#{pane_active}|#{pane_current_path}|#{pane_current_command}')

      while IFS='|' read -r p_idx p_active p_cwd p_cmd; do
        printf "      - index: %s\n" "$p_idx"
        printf "        active: %s\n" "$(bool_from_flag "$p_active")"
        printf "        cwd: %s\n" "$(yaml_squote "$p_cwd")"
        printf "        command: %s\n" "$(yaml_squote "$p_cmd")"
      done <<< "$panes"
    done <<< "$windows"
  } > "$out"

  echo "Saved: $out"
}

# ─── main fzf menu ───────────────────────────────────────────────────────────

main() {
  local action_file
  action_file="$(mktemp /tmp/tsm_action.XXXXXX)"
  # ensure cleanup on exit
  trap 'rm -f "$action_file"' RETURN

  local create_token="[+] Create new session"
  local header
  header=$'↑↓/jk:move  ↵:attach  d/⌫:delete  n:new  E:detach  q/ESC:quit\nr:rename  s:save  R:restore-saved'

  local selected
  selected=$(
    {
      tmux list-sessions -F "#{session_name}" 2>/dev/null || true
      echo "$create_token"
    } | fzf \
        --ansi --reverse --no-sort \
        --prompt="tmux session > " \
        --header="$header" \
        --preview='tmux list-windows -t {} -F "  #{window_index}: #{window_name}  (#{window_panes} panes)" 2>/dev/null || echo "  Create a new session"' \
        --preview-window='right:40%:wrap' \
        --bind "enter:accept" \
        --bind "space:accept" \
        --bind "j:down,k:up" \
        --bind "q:abort,esc:abort" \
        --bind "d:execute-silent({ printf 'delete:'; printf '%s' {}; } > '$action_file')+abort" \
        --bind "backspace:execute-silent({ printf 'delete:'; printf '%s' {}; } > '$action_file')+abort" \
        --bind "n:execute-silent(printf 'new' > '$action_file')+abort" \
        --bind "N:execute-silent(printf 'new' > '$action_file')+abort" \
        --bind "r:execute-silent({ printf 'rename:'; printf '%s' {}; } > '$action_file')+abort" \
        --bind "s:execute-silent({ printf 'save:'; printf '%s' {}; } > '$action_file')+abort" \
        --bind "R:execute-silent(printf 'restore' > '$action_file')+abort" \
        --bind "E:execute-silent(printf 'detach' > '$action_file')+abort" \
      || true
  )

  local action=""
  [[ -s "$action_file" ]] && action="$(<"$action_file")"

  # resolve action from enter-select on create token
  [[ "$selected" == "$create_token" ]] && action="new"

  case "$action" in
    delete:*)
      local target="${action#delete:}"
      [[ "$target" == "$create_token" ]] && { main; return; }
      do_delete "$target"
      ;;
    rename:*)
      local target="${action#rename:}"
      [[ "$target" == "$create_token" ]] && { main; return; }
      do_rename "$target"
      ;;
    save:*)
      local target="${action#save:}"
      [[ "$target" == "$create_token" ]] && { main; return; }
      do_save "$target" || true
      sleep 0.4
      main
      ;;
    restore)   do_restore ;;
    new)       do_new ;;
    detach)    do_detach ;;
    "")
      # fzf aborted with no action file written (q / ESC) — just exit
      [[ -z "$selected" ]] && return 0
      do_attach "$selected"
      ;;
  esac
}

# ─── CLI ─────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
tsm $VERSION - tmux session manager

Usage: tsm [command]

Commands:
  (none)            Open interactive session picker
  new [name]        Create and attach a new session
  ls                List all sessions
  kill [name]       Kill a session (picker if name omitted)
  kill --all        Kill multiple sessions (fzf multi-select, TAB to select)
  rename <old> <new>  Rename a session
  config [--read]   Read tmux config (default)
  config --edit     Edit tmux config, prompt to reload after
  config --reload   Reload tmux config (must be inside tmux)
  config --tsm      Edit tsm's own config (~/.config/tsm/config.yaml)
  save [name]       Save session layout to ~/.config/tsm/sessions/<name>.yaml
                    (uses current session if name omitted)
  save --list       List saved configs with metadata
  save --delete [name]  Delete a saved config (fzf picker if name omitted)
  restore [name]              Restore a saved session (fzf picker if omitted)
  restore --with-commands [name]
                              Restore layout and re-run saved commands
                              (skips: bash zsh sh fish dash tmux)
  log <action>      Pane output logging (see 'tsm log help')
  version           Show version
  help              Show this help

Keybindings (inside picker):
  ↑↓ / j k    Navigate
  Enter/Space  Attach to session
  d / ⌫       Delete session
  n / N        New session
  r            Rename selected session
  s            Save selected session layout
  R            Restore a saved session (opens picker)
  E            Detach current client
  q / ESC      Quit
EOF
}

# __write is called per line of pane output via tmux pipe-pane — skip config loading
# to avoid spawning multiple yq processes on the hot path.
if [[ "${1:-}" != "log" || "${2:-}" != "__write" ]]; then
  load_config
  apply_env_overrides
fi

case "${1:-}" in
  "")       check_deps; main ;;
  new)
    check_deps
    if [[ -n "${2:-}" ]]; then
      if tmux has-session -t "$2" 2>/dev/null; then
        echo "Session '$2' already exists. Attaching." >&2
        do_attach "$2"
      elif in_tmux; then
        tmux new-session -d -s "$2"
        tmux switch-client -t "$2"
      else
        tmux new-session -s "$2"
      fi
    else
      do_new
    fi
    ;;
  ls|list)  tmux list-sessions 2>/dev/null || echo "No tmux sessions." ;;
  rename)
    check_deps
    if [[ -z "${2:-}" ]] || [[ -z "${3:-}" ]]; then
      echo "Usage: tsm rename <old-name> <new-name>" >&2; exit 1
    fi
    tmux rename-session -t "$2" "$3" && echo "Renamed '$2' → '$3'"
    ;;
  kill)
    check_deps
    if [[ "${2:-}" == "--all" ]]; then
      pick_kill_multi
    elif [[ -n "${2:-}" ]]; then
      do_kill "$2"
    else
      pick_kill
    fi
    ;;
  config)
    case "${2:---read}" in
      --read)   do_config_read ;;
      --edit)   do_config_edit ;;
      --reload) do_config_reload ;;
      --tsm)    do_config_tsm ;;
      *) echo "tsm config: unknown option '${2}'" >&2; usage >&2; exit 1 ;;
    esac
    ;;
  save)
    case "${2:-}" in
      --list)   do_save_list ;;
      --delete) check_deps; do_save_delete "${3:-}" ;;
      *)        check_deps; do_save "${2:-}" ;;
    esac
    ;;
  restore)
    check_deps
    shift
    do_restore "$@"
    ;;
  log)
    case "${2:-}" in
      start)   check_deps; do_log_start  "${3:-}" ;;
      stop)    check_deps; do_log_stop   "${3:-}" ;;
      status)  check_deps; do_log_status ;;
      list)    do_log_list "${3:-}" ;;
      show)    check_deps; shift 2; do_log_show "$@" ;;
      tail)    check_deps; shift 2; do_log_tail "$@" ;;
      clean)   do_log_clean "${3:-}" ;;
      __write) do_log_write "${3:-}" "${4:-}" ;;
      help|"")
        cat <<EOF
tsm log <action>

Actions:
  start [target|--all]   Start logging current pane (or --all in current session)
  stop  [target|--all]   Stop logging
  status                 Show panes currently being logged
  list  [session]        List log files (optionally filter by session)
  show  [target] [--plain]
                         View log via \$PAGER (--plain strips ANSI escapes)
  tail  [target] [--plain]
                         Follow log in real time (like tail -f)
  clean [session|--all]  Delete log files

Default target: current pane.
Logs: \$XDG_DATA_HOME/tsm/logs/<session>/<window>.<pane>.log
Size cap: 10 MB by default. Override via config file (log_max_bytes) or \$TSM_LOG_MAX_BYTES.
EOF
        ;;
      *) echo "tsm log: unknown action '${2}'" >&2; exit 1 ;;
    esac
    ;;
  version)  echo "tsm $VERSION" ;;
  help|-h|--help) usage ;;
  *)        echo "tsm: unknown command '$1'" >&2; usage >&2; exit 1 ;;
esac
