#!/usr/bin/env bash
# tsm - tmux session manager
# A lightweight fzf-based tmux session manager
# https://github.com/hnts03/tmux-session-manager

set -euo pipefail

VERSION="0.5.0"

# ─── config defaults (overridden by config file, then env vars) ──────────────

_TSM_SESSIONS_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/tsm/sessions"
_TSM_LOGS_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/tsm/logs"
_TSM_LOG_MAX_BYTES=10485760
_TSM_RESTORE_SKIP_COMMANDS=(bash zsh sh fish dash tmux vim nvim top htop less)
_TSM_AUTO_LOG=true
_TSM_POPUP=false
_TSM_POPUP_SIZE="80%"

# ─── dependency check ────────────────────────────────────────────────────────

check_deps() {
  local missing=()
  command -v tmux &>/dev/null || missing+=("tmux")
  command -v fzf  &>/dev/null || missing+=("fzf")
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "tsm: missing required dependencies: ${missing[*]}" >&2
    echo "Install them and try again." >&2
    exit 1
  fi
}

require_yq() {
  if ! command -v yq &>/dev/null; then
    echo "tsm: 'yq' is required for save/restore. Install with: brew install yq" >&2
    exit 1
  fi
}

sessions_dir()       { echo "$_TSM_SESSIONS_DIR"; }
logs_dir()           { echo "$_TSM_LOGS_DIR"; }
groups_dir()         { echo "${XDG_CONFIG_HOME:-$HOME/.config}/tsm/groups"; }
tsm_self_config_path() { echo "${XDG_CONFIG_HOME:-$HOME/.config}/tsm/config.yaml"; }

# Sanitize a session name for use as a config filename (replace / with _)
config_name_for() { printf '%s' "${1//\//_}"; }

load_config() {
  local config_file
  config_file="$(tsm_self_config_path)"
  [[ ! -f "$config_file" ]] && return 0
  if ! command -v yq &>/dev/null; then
    echo "tsm: config file found at $config_file but 'yq' is required to read it." >&2
    echo "     Install with: brew install yq  (falling back to defaults)" >&2
    return 0
  fi
  local val skip_count
  val=$(yq -r '.sessions_dir // ""' "$config_file" 2>/dev/null)
  [[ -n "$val" ]] && _TSM_SESSIONS_DIR="${val/#\~/$HOME}"
  val=$(yq -r '.logs_dir // ""' "$config_file" 2>/dev/null)
  [[ -n "$val" ]] && _TSM_LOGS_DIR="${val/#\~/$HOME}"
  val=$(yq -r '.log_max_bytes // ""' "$config_file" 2>/dev/null)
  [[ -n "$val" ]] && _TSM_LOG_MAX_BYTES="$val"
  skip_count=$(yq -r '(.restore_skip_commands // []) | length' "$config_file" 2>/dev/null)
  if [[ "${skip_count:-0}" -gt 0 ]]; then
    _TSM_RESTORE_SKIP_COMMANDS=()
    while IFS= read -r cmd; do
      _TSM_RESTORE_SKIP_COMMANDS+=("$cmd")
    done < <(yq -r '.restore_skip_commands[]' "$config_file")
  fi
  val=$(yq -r '.auto_log // ""' "$config_file" 2>/dev/null)
  [[ "$val" == "false" ]] && _TSM_AUTO_LOG=false
  [[ "$val" == "true"  ]] && _TSM_AUTO_LOG=true
  val=$(yq -r '.popup // ""' "$config_file" 2>/dev/null)
  [[ "$val" == "false" ]] && _TSM_POPUP=false
  [[ "$val" == "true"  ]] && _TSM_POPUP=true
  val=$(yq -r '.popup_size // ""' "$config_file" 2>/dev/null)
  [[ -n "$val" ]] && _TSM_POPUP_SIZE="$val"
  return 0
}

apply_env_overrides() {
  _TSM_LOG_MAX_BYTES="${TSM_LOG_MAX_BYTES:-$_TSM_LOG_MAX_BYTES}"
  _TSM_SESSIONS_DIR="${TSM_SESSIONS_DIR:-$_TSM_SESSIONS_DIR}"
  _TSM_LOGS_DIR="${TSM_LOGS_DIR:-$_TSM_LOGS_DIR}"
  [[ "${TSM_AUTO_LOG:-}" == "false" ]] && _TSM_AUTO_LOG=false
  [[ "${TSM_AUTO_LOG:-}" == "true"  ]] && _TSM_AUTO_LOG=true
  [[ "${TSM_POPUP:-}" == "false" ]] && _TSM_POPUP=false
  [[ "${TSM_POPUP:-}" == "true"  ]] && _TSM_POPUP=true
  _TSM_POPUP_SIZE="${TSM_POPUP_SIZE:-$_TSM_POPUP_SIZE}"
  return 0
}

# resolve a target to absolute pane id; default = current pane
resolve_pane_target() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    if ! in_tmux; then
      echo "tsm log: must be inside tmux or specify a target." >&2
      return 1
    fi
    target=$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}')
  fi
  echo "$target"
}

# build the log file path for a session/window/pane triple (pure string, no tmux calls)
pane_log_path() {
  echo "$(logs_dir)/$1/$2.$3.log"
}

# convert "session:window.pane" target to a log file path
log_file_for() {
  local target="$1"
  local session window pane
  session=$(tmux display-message -t "$target" -p '#{session_name}' 2>/dev/null) || return 1
  window=$(tmux display-message  -t "$target" -p '#{window_index}' 2>/dev/null) || return 1
  pane=$(tmux display-message    -t "$target" -p '#{pane_index}' 2>/dev/null) || return 1
  pane_log_path "$session" "$window" "$pane"
}

# ─── helpers ─────────────────────────────────────────────────────────────────

in_tmux()      { [[ -n "${TMUX:-}" ]]; }
current_session() { tmux display-message -p '#S' 2>/dev/null; }

# true iff the installed tmux is >= 3.2 (when `display-popup -E` became available)
tmux_supports_popup() {
  local have
  have=$(tmux -V 2>/dev/null | sed -E 's/^tmux //; s/[^0-9.].*//')
  [[ -n "$have" ]] || return 1
  # version >= 3.2  ⇔  the smaller of {3.2, have} is 3.2
  [[ "$(printf '3.2\n%s\n' "$have" | sort -V | head -1)" == "3.2" ]]
}

# Decide whether the no-arg picker should open in a popup or full-screen.
# $1: override — "force-on" (--popup), "force-off" (--no-popup), or "" (use config).
# Echoes "popup" or "inline".
should_use_popup() {
  local override="${1:-}"
  # Never re-popup from inside a tsm popup (recursion guard).
  [[ -n "${TSM_IN_POPUP:-}" ]] && { echo "inline"; return; }
  [[ "$override" == "force-off" ]] && { echo "inline"; return; }
  local want=false
  [[ "$override" == "force-on" ]] && want=true
  [[ -z "$override" && "$_TSM_POPUP" == "true" ]] && want=true
  if $want && in_tmux && tmux_supports_popup; then
    echo "popup"
  else
    echo "inline"
  fi
}

# Open the picker inside a tmux display-popup; the inner tsm runs the normal picker.
launch_popup() {
  local size="$_TSM_POPUP_SIZE"
  local self_q
  printf -v self_q '%q' "$(command -v "$0" 2>/dev/null || printf '%s' "$0")"
  # `env VAR=… cmd` is shell-agnostic: the bare `VAR=… cmd` prefix is not valid
  # syntax under a fish default-shell, which tmux may use to run the popup command.
  tmux display-popup -E -w "$size" -h "$size" "env TSM_IN_POPUP=1 $self_q"
}

# Entry point for the interactive picker: popup or full-screen based on flags/config.
run_picker() {
  local override="${1:-}"
  if [[ "$(should_use_popup "$override")" == "popup" ]]; then
    launch_popup
  else
    main
  fi
}

# ─── actions ─────────────────────────────────────────────────────────────────

do_attach() {
  local session="$1"
  if in_tmux; then
    tmux switch-client -t "=$session"
  else
    tmux attach-session -t "=$session"
  fi
}

do_new() {
  printf "Enter new session name: "
  read -r new_name
  if [[ -z "$new_name" ]]; then
    echo "No name entered. Aborted."
    sleep 0.4
    main
    return
  fi
  if tmux has-session -t "=$new_name" 2>/dev/null; then
    printf "Session '%s' already exists. Attach to it? [Y/n] " "$new_name"
    read -r confirm
    if [[ ! "$confirm" =~ ^[nN]$ ]]; then
      do_attach "$new_name"
    else
      sleep 0.4
      main
    fi
    return
  fi
  if in_tmux; then
    tmux new-session -d -s "$new_name"
    [[ "$_TSM_AUTO_LOG" == "true" ]] && do_log_start "$new_name" 2>/dev/null || true
    tmux switch-client -t "=$new_name"
  else
    tmux new-session -s "$new_name"
  fi
}

do_delete() {
  local session="$1"
  if in_tmux && [[ "$session" == "$(current_session)" ]]; then
    echo "Cannot delete the currently attached session '$session'." >&2
    sleep 1
    main
    return
  fi
  printf "Delete session '%s'? [y/N] " "$session"
  read -r confirm
  if [[ "$confirm" =~ ^[yY]$ ]]; then
    tmux kill-session -t "=$session"
    echo "Deleted session: $session"
  else
    echo "Cancelled."
  fi
  sleep 0.4
  main
}

do_detach() {
  if in_tmux; then
    tmux detach-client
  else
    echo "Not inside a tmux session." >&2
    sleep 1
  fi
}

do_rename() {
  local old_name="$1"
  printf "New name for '%s': " "$old_name"
  read -r new_name
  if [[ -z "$new_name" ]]; then
    echo "No name entered. Aborted."
    sleep 0.4
    main
    return
  fi
  tmux rename-session -t "=$old_name" "$new_name" && echo "Renamed '$old_name' → '$new_name'"
  sleep 0.4
  main
}

do_kill() {
  local session="$1"
  if in_tmux && [[ "$session" == "$(current_session)" ]]; then
    echo "tsm: cannot kill the currently attached session '$session'." >&2
    exit 1
  fi
  tmux kill-session -t "=$session" && echo "Killed session: $session"
}

pick_kill() {
  local session
  session=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | \
    fzf --ansi --reverse --no-sort --prompt="kill session > ") || return 0
  [[ -z "$session" ]] && return 0
  do_kill "$session"
}

pick_kill_multi() {
  local sessions
  sessions=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | \
    fzf --ansi --reverse --no-sort --multi --prompt="kill sessions (TAB to select) > ") || return 0
  [[ -z "$sessions" ]] && return 0
  while read -r session; do
    if in_tmux && [[ "$session" == "$(current_session)" ]]; then
      echo "tsm: skipping current session '$session'" >&2
      continue
    fi
    tmux kill-session -t "=$session" && echo "Killed session: $session"
  done <<< "$sessions"
}

tmux_config_path() {
  if [[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf" ]]; then
    echo "${XDG_CONFIG_HOME:-$HOME/.config}/tmux/tmux.conf"
  else
    echo "$HOME/.tmux.conf"
  fi
}

do_config_read() {
  local config
  config="$(tmux_config_path)"
  if [[ ! -f "$config" ]]; then
    echo "tsm: no tmux config found at $config" >&2
    exit 1
  fi
  local editor="${VISUAL:-${EDITOR:-vi}}"
  case "$(basename "$editor")" in
    vi|vim|nvim) "$editor" -R "$config" ;;
    nano)        "$editor" -v "$config" ;;
    *)           "$editor" "$config" ;;
  esac
}

do_config_reload() {
  if ! in_tmux; then
    echo "tsm: must be inside a tmux session to reload config." >&2
    exit 1
  fi
  local config
  config="$(tmux_config_path)"
  tmux source-file "$config" && echo "Reloaded: $config"
}

do_config_edit() {
  local config
  config="$(tmux_config_path)"
  local editor="${VISUAL:-${EDITOR:-vi}}"
  "$editor" "$config"
  printf "Reload tmux config now? [y/N] "
  read -r confirm
  if [[ "$confirm" =~ ^[yY]$ ]]; then
    do_config_reload
  fi
}

do_config_tsm() {
  local config_file
  config_file="$(tsm_self_config_path)"
  if [[ ! -f "$config_file" ]]; then
    mkdir -p "$(dirname "$config_file")"
    cat > "$config_file" <<'EOF'
# tsm configuration — uncomment and edit values to override defaults.
# log_max_bytes: 10485760          # 10 MB
# sessions_dir: ~/.config/tsm/sessions
# logs_dir: ~/.local/share/tsm/logs
# restore_skip_commands:
#   - bash
#   - zsh
#   - sh
#   - fish
#   - dash
#   - tmux
#   - vim
#   - nvim
#   - top
#   - htop
#   - less
# auto_log: true                   # auto-start logging when tsm creates a session
# popup: false                     # run the picker in a tmux display-popup (tmux >= 3.2)
# popup_size: 80%                  # popup width & height
EOF
    echo "Created: $config_file"
  fi
  local editor="${VISUAL:-${EDITOR:-vi}}"
  "$editor" "$config_file"
}

# ─── save / restore ──────────────────────────────────────────────────────────

# YAML-safe single-quoted string: '' is the single-quote escape inside single quotes
yaml_squote() {
  local s="$1"
  printf "'%s'" "${s//\'/\'\'}"
}

bool_from_flag() {
  [[ "$1" == "1" ]] && echo "true" || echo "false"
}

is_skip_command() {
  local cmd="$1" skip
  for skip in "${_TSM_RESTORE_SKIP_COMMANDS[@]}"; do
    [[ "$cmd" == "$skip" ]] && return 0
  done
  return 1
}

do_restore_preview() {
  local name="${1:-}"
  [[ -z "$name" ]] && return 0

  local file
  file="$(sessions_dir)/$(config_name_for "$name").yaml"

  if tmux has-session -t "=$name" 2>/dev/null; then
    local pane_id win_info
    pane_id=$(tmux display-message -t "$name" \
      -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)
    win_info=$(tmux display-message -t "$name" -p '#I:#W' 2>/dev/null)
    printf '  \e[32m●\e[0m RUNNING  \033[2m[%s]\033[0m\n' "$win_info"
    tmux capture-pane -p -e -t "$pane_id" 2>/dev/null
    return 0
  fi

  printf '  ○ not running\n'
  printf '  ───────────────────────\n'

  if [[ ! -f "$file" ]]; then
    printf '  (config not found)\n'
    return 0
  fi

  if command -v yq &>/dev/null; then
    local date_str n_windows n_panes
    date_str=$(yq -r '.created_at // ""' "$file" 2>/dev/null | cut -c1-10)
    n_windows=$(yq -r '.windows | length' "$file" 2>/dev/null)
    n_panes=$(yq -r '[.windows[].panes | length] | add // 0' "$file" 2>/dev/null)
    printf '  Saved:  %s\n' "$date_str"
    printf '  Layout: %sw · %sp\n\n' "${n_windows:-0}" "${n_panes:-0}"
    yq -r '.windows[] | "  \(.index): \(.name)  (\(.panes|length) pane(s))"' "$file" 2>/dev/null
  else
    cat "$file"
  fi
  return 0
}

pick_config() {
  local dir
  dir="$(sessions_dir)"
  if [[ ! -d "$dir" ]]; then
    echo "tsm restore: no saved configs (directory $dir does not exist)." >&2
    return 1
  fi
  local configs
  configs=$(find "$dir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null \
    | sed -e 's|.*/||' -e 's|\.yaml$||')
  if [[ -z "$configs" ]]; then
    echo "tsm restore: no saved configs in $dir." >&2
    return 1
  fi

  local action_file
  action_file="$(mktemp /tmp/tsm_restore.XXXXXX)"
  trap 'rm -f "$action_file"' RETURN

  local self_q
  printf -v self_q '%q' "$0"

  local picked
  picked=$(echo "$configs" | fzf --ansi --reverse --no-sort \
    --prompt="restore > " \
    --header=$'↑↓/jk:move  ↵:restore (layout only)  W:restore+commands  q/ESC:cancel' \
    --preview="$self_q restore __preview {}" \
    --preview-window='right:45%:wrap' \
    --bind "j:down,k:up" \
    --bind "q:abort,esc:abort" \
    --bind "W:execute-silent(printf 'with-commands' > '$action_file')+accept" \
  ) || { rm -f "$action_file"; return 1; }
  [[ -z "$picked" ]] && { rm -f "$action_file"; return 1; }

  local mode="layout-only"
  [[ -s "$action_file" ]] && mode="$(<"$action_file")"
  rm -f "$action_file"

  printf '%s\n%s\n' "$picked" "$mode"
}

do_restore() {
  local with_commands=false no_attach=false
  local name=""

  for arg in "$@"; do
    case "$arg" in
      --with-commands) with_commands=true ;;
      --no-attach)     no_attach=true ;;
      *) [[ -z "$name" ]] && name="$arg" ;;
    esac
  done

  if [[ -z "$name" ]]; then
    local pick_result
    pick_result="$(pick_config)" || return 0
    name="${pick_result%%$'\n'*}"
    local pick_mode="${pick_result##*$'\n'}"
    [[ "$pick_mode" == "with-commands" ]] && with_commands=true
  fi

  local file
  file="$(sessions_dir)/$(config_name_for "$name").yaml"
  if [[ ! -f "$file" ]]; then
    echo "tsm restore: config not found: $file" >&2
    exit 1
  fi

  require_yq

  local session
  session=$(yq -r '.name' "$file")

  if tmux has-session -t "=$session" 2>/dev/null; then
    echo "tsm restore: session '$session' already exists." >&2
    echo "Overwrite is not yet supported — kill it first or rename the config." >&2
    exit 1
  fi

  local windows_data
  windows_data=$(yq -r '.windows | to_entries[] | "\(.key)|\(.value.name)|\(.value.layout)|\(.value.active)"' "$file")

  local first=true
  local active_window=""

  while IFS='|' read -r wi w_name w_layout w_active; do
    local n_panes first_cwd
    n_panes=$(yq -r ".windows[$wi].panes | length" "$file")
    first_cwd=$(yq -r ".windows[$wi].panes[0].cwd" "$file")

    if $first; then
      tmux new-session -d -s "$session" -n "$w_name" -c "$first_cwd"
      first=false
    else
      tmux new-window -t "$session" -n "$w_name" -c "$first_cwd"
    fi

    local current_idx first_pane_idx
    current_idx=$(tmux display-message -t "$session:" -p '#{window_index}')
    first_pane_idx=$(tmux display-message -t "$session:$current_idx" -p '#{pane_index}')

    local pane_targets=("$session:$current_idx.$first_pane_idx")

    local pi
    for ((pi=1; pi<n_panes; pi++)); do
      local p_cwd
      p_cwd=$(yq -r ".windows[$wi].panes[$pi].cwd" "$file")
      tmux split-window -t "$session:$current_idx" -c "$p_cwd"
      local new_pane_idx
      new_pane_idx=$(tmux display-message -t "$session:$current_idx" -p '#{pane_index}')
      pane_targets+=("$session:$current_idx.$new_pane_idx")
    done

    tmux select-layout -t "$session:$current_idx" "$w_layout" 2>/dev/null \
      || { tmux select-layout -t "$session:$current_idx" even-horizontal 2>/dev/null || true
           echo "tsm restore: warning — layout mismatch for window '$w_name'; applied even-horizontal" >&2; }

    if $with_commands; then
      for ((pi=0; pi<n_panes; pi++)); do
        local p_cmd
        p_cmd=$(yq -r ".windows[$wi].panes[$pi].command" "$file")
        if [[ -n "$p_cmd" ]] && ! is_skip_command "$p_cmd"; then
          tmux send-keys -t "${pane_targets[$pi]}" "$p_cmd" Enter
        fi
      done
    fi

    # Print historical log path directly to each pane's TTY (no shell history pollution).
    # Delayed 0.2s to let the shell finish startup before we write.
    for ((pi=0; pi<n_panes; pi++)); do
      local p_log_file
      p_log_file=$(yq -r ".windows[$wi].panes[$pi].log_file // \"\"" "$file" 2>/dev/null)
      [[ -z "$p_log_file" || "$p_log_file" == "null" || ! -f "$p_log_file" ]] && continue
      local pane_tty
      pane_tty=$(tmux display-message -t "${pane_targets[$pi]}" -p '#{pane_tty}' 2>/dev/null) || continue
      [[ -z "$pane_tty" ]] && continue
      ( sleep 0.2; printf '\033[2mtsm: recent working history → %s\033[0m\r\n' \
        "$p_log_file" > "$pane_tty" 2>/dev/null ) &
    done

    [[ "$w_active" == "true" ]] && active_window="$current_idx"
  done <<< "$windows_data"

  [[ -n "$active_window" ]] && tmux select-window -t "$session:$active_window"

  echo "Restored: $session"
  if ! $no_attach; then
    if in_tmux; then
      tmux switch-client -t "=$session"
    else
      tmux attach-session -t "=$session"
    fi
  fi
}

do_clone() {
  local source="${1:-}" new_name="${2:-}"

  if [[ -z "$source" ]]; then
    if ! in_tmux; then
      echo "tsm clone: must be inside tmux or specify a source session." >&2
      return 1
    fi
    source="$(current_session)"
  fi

  if ! tmux has-session -t "=$source" 2>/dev/null; then
    echo "tsm clone: session '$source' not found." >&2
    return 1
  fi

  if [[ -z "$new_name" ]]; then
    printf "New session name (clone of '%s'): " "$source"
    read -r new_name
    [[ -z "$new_name" ]] && { echo "Cancelled."; return 0; }
  fi

  if tmux has-session -t "=$new_name" 2>/dev/null; then
    echo "tsm clone: session '$new_name' already exists." >&2
    return 1
  fi

  local windows_data
  windows_data=$(tmux list-windows -t "=$source" \
    -F "#{window_index}|#{window_name}|#{window_layout}|#{window_active}")

  local first=true active_window=""

  while IFS='|' read -r wi w_name w_layout w_active; do
    local panes_data first_cwd
    panes_data=$(tmux list-panes -t "=$source:$wi" \
      -F "#{pane_index}|#{pane_current_path}")
    first_cwd=$(printf '%s\n' "$panes_data" | head -1 | cut -d'|' -f2)
    [[ -z "$first_cwd" ]] && first_cwd="$HOME"

    if $first; then
      tmux new-session -d -s "$new_name" -n "$w_name" -c "$first_cwd"
      first=false
    else
      tmux new-window -t "$new_name" -n "$w_name" -c "$first_cwd"
    fi

    local current_idx
    current_idx=$(tmux display-message -t "$new_name:" -p '#{window_index}')

    local skip_first=true
    while IFS='|' read -r _pi p_cwd; do
      if $skip_first; then skip_first=false; continue; fi
      [[ -z "$p_cwd" ]] && p_cwd="$HOME"
      tmux split-window -t "$new_name:$current_idx" -c "$p_cwd"
    done <<< "$panes_data"

    tmux select-layout -t "$new_name:$current_idx" "$w_layout" 2>/dev/null \
      || { tmux select-layout -t "$new_name:$current_idx" even-horizontal 2>/dev/null || true
           echo "tsm clone: warning — layout mismatch for window '$w_name'" >&2; }

    [[ "$w_active" == "1" ]] && active_window="$current_idx"
  done <<< "$windows_data"

  [[ -n "$active_window" ]] && tmux select-window -t "$new_name:$active_window" 2>/dev/null || true
  [[ "$_TSM_AUTO_LOG" == "true" ]] && do_log_start "$new_name" 2>/dev/null || true

  echo "Cloned '$source' → '$new_name'"
  do_attach "$new_name"
}

# ─── pane output logging ─────────────────────────────────────────────────────

# internal: read stdin, append to file with size cap + rotation
# Usage (called by tmux pipe-pane): tsm log __write <file> <max_bytes>
do_log_write() {
  local file="$1"
  local max="${2:-10485760}"
  local timestamp="${3:-false}"
  mkdir -p "$(dirname "$file")"
  awk -v file="$file" -v max="$max" -v ts="$timestamp" '
    BEGIN {
      cmd = "wc -c < \"" file "\" 2>/dev/null"
      cmd | getline written
      close(cmd)
      written = written + 0
    }
    {
      line = (ts == "true") ? (strftime("[%Y-%m-%dT%H:%M:%S] ", systime()) $0) : $0
      print line >> file
      fflush(file)
      written += length(line) + 1
      if (written >= max) {
        close(file)
        system("mv \"" file "\" \"" file ".1\" 2>/dev/null")
        written = 0
      }
    }
  '
}

_panes_for_target() {
  # expand a target into list of session:window.pane
  local arg="$1"
  if [[ "$arg" == "--all" ]]; then
    in_tmux || { echo "tsm log: --all requires being inside tmux." >&2; return 1; }
    local session
    session=$(current_session)
    tmux list-panes -s -t "$session" \
      -F '#{session_name}:#{window_index}.#{pane_index}'
  elif [[ "$arg" == "--all-sessions" ]]; then
    tmux list-panes -a \
      -F '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null
  else
    resolve_pane_target "$arg" || return 1
  fi
}

do_log_start() {
  local arg="" timestamp=false
  for a in "$@"; do
    case "$a" in
      --timestamp) timestamp=true ;;
      *) [[ -z "$arg" ]] && arg="$a" ;;
    esac
  done

  if $timestamp; then
    if ! awk 'BEGIN { strftime("%Y", systime()); exit 0 }' 2>/dev/null; then
      echo "tsm: --timestamp requires awk with strftime/systime support." >&2
      echo "     Install gawk: brew install gawk  (or: apt install gawk)" >&2
      return 1
    fi
  fi

  local self="${TSM_SELF:-$(command -v "$0" 2>/dev/null || printf '%s' "$0")}"
  local max="${TSM_LOG_MAX_BYTES:-$_TSM_LOG_MAX_BYTES}"

  local self_q
  printf -v self_q '%q' "$self"

  local panes
  panes=$(_panes_for_target "$arg") || return 1

  local ts_flag="$timestamp"
  local skip_existing=false
  [[ "$arg" == "--all-sessions" ]] && skip_existing=true

  while read -r p; do
    [[ -z "$p" ]] && continue
    if $skip_existing; then
      local piped
      piped=$(tmux display-message -t "$p" -p '#{pane_pipe}' 2>/dev/null) || continue
      [[ "$piped" == "1" ]] && continue
    fi
    local file
    file=$(log_file_for "$p") || continue
    mkdir -p "$(dirname "$file")"
    local file_q
    printf -v file_q '%q' "$file"
    # close any existing pipe first to avoid double-piping
    tmux pipe-pane -t "$p"
    tmux pipe-pane -t "$p" "$self_q log __write $file_q $max $ts_flag"
    echo "Logging: $p → $file"
  done <<< "$panes"
}

do_log_stop() {
  local arg="${1:-}"
  local panes
  panes=$(_panes_for_target "$arg") || return 1
  while read -r p; do
    [[ -z "$p" ]] && continue
    tmux pipe-pane -t "$p"
    echo "Stopped: $p"
  done <<< "$panes"
}

do_log_toggle() {
  local arg="${1:-}"
  # Check if ANY pane in the session is currently being logged
  local session
  if [[ "$arg" == *:* ]]; then
    session="${arg%%:*}"
  else
    session="$arg"
  fi
  local any_logged
  any_logged=$(tmux list-panes -s -t "=$session" \
    -F '#{pane_pipe} #{session_name}:#{window_index}.#{pane_index}' 2>/dev/null | \
    awk '$1==1{print $2}')
  if [[ -n "$any_logged" ]]; then
    while IFS= read -r p; do
      [[ -z "$p" ]] && continue
      tmux pipe-pane -t "$p"
      echo "Stopped: $p"
    done <<< "$any_logged"
  else
    do_log_start "$arg"
  fi
}

do_log_status() {
  local format='#{session_name}:#{window_index}.#{pane_index}|#{pane_pipe}'
  local any=false
  while IFS='|' read -r target piped; do
    if [[ "$piped" == "1" ]]; then
      local file
      file=$(log_file_for "$target")
      local size="-"
      [[ -f "$file" ]] && size=$(wc -c < "$file" 2>/dev/null | tr -d ' ')
      printf "  %-30s %10s bytes  %s\n" "$target" "$size" "$file"
      any=true
    fi
  done < <(tmux list-panes -a -F "$format" 2>/dev/null)
  $any || echo "No panes are being logged."
}

do_log_list() {
  local session="${1:-}"
  local dir
  dir=$(logs_dir)
  if [[ -n "$session" ]]; then
    dir="$dir/$session"
  fi
  if [[ ! -d "$dir" ]]; then
    echo "No log files in $dir"
    return 0
  fi
  find "$dir" -type f \( -name '*.log' -o -name '*.log.1' \) | sort | while read -r f; do
    local size
    size=$(wc -c < "$f" 2>/dev/null | tr -d ' ')
    printf "  %10s bytes  %s\n" "$size" "$f"
  done
}

do_log_show() {
  local target="" plain=false
  for a in "$@"; do
    case "$a" in
      --plain) plain=true ;;
      *)       [[ -z "$target" ]] && target="$a" ;;
    esac
  done

  local resolved
  resolved=$(resolve_pane_target "$target") || exit 1
  local file
  file=$(log_file_for "$resolved") || exit 1
  if [[ ! -f "$file" ]]; then
    echo "tsm log show: no log file for $resolved ($file)" >&2
    exit 1
  fi
  local pager="${PAGER:-less -R}"
  if $plain; then
    sed -E $'s/\x1b\\[[0-9;?]*[a-zA-Z]//g; s/\x1b\\][^\x07]*\x07//g' "$file" | $pager
  else
    $pager "$file"
  fi
}

do_log_tail() {
  local target="" plain=false
  for a in "$@"; do
    case "$a" in
      --plain) plain=true ;;
      *)       [[ -z "$target" ]] && target="$a" ;;
    esac
  done

  local resolved
  resolved=$(resolve_pane_target "$target") || exit 1
  local file
  file=$(log_file_for "$resolved") || exit 1
  if [[ ! -f "$file" ]]; then
    echo "tsm log tail: no log file for $resolved ($file)" >&2
    exit 1
  fi
  if $plain; then
    tail -F "$file" | sed -E $'s/\x1b\\[[0-9;?]*[a-zA-Z]//g; s/\x1b\\][^\x07]*\x07//g'
  else
    tail -F "$file"
  fi
}

do_log_grep() {
  local pattern="" target="" plain=false all=false
  for a in "$@"; do
    case "$a" in
      --plain) plain=true ;;
      --all)   all=true ;;
      *)
        if [[ -z "$pattern" ]]; then
          pattern="$a"
        elif [[ -z "$target" ]]; then
          target="$a"
        fi
        ;;
    esac
  done

  if [[ -z "$pattern" ]]; then
    echo "Usage: tsm log grep [--plain] [--all] <pattern> [target]" >&2
    exit 1
  fi

  if $all; then
    local dir
    dir="$(logs_dir)"
    if [[ ! -d "$dir" ]]; then
      echo "tsm log grep: no logs directory ($dir)" >&2
      exit 1
    fi
    local found=0
    while IFS= read -r f; do
      [[ -z "$f" || ! -f "$f" ]] && continue
      local session wp pane_label content
      session=$(basename "$(dirname "$f")")
      wp=$(basename "$f" .log)
      pane_label="${session}:${wp}"
      if $plain; then
        content=$(sed -E $'s/\x1b\\[[0-9;?]*[a-zA-Z]//g; s/\x1b\\][^\x07]*\x07//g' \
          "$f" 2>/dev/null | grep -- "$pattern" 2>/dev/null) || content=""
      else
        content=$(grep -- "$pattern" "$f" 2>/dev/null) || content=""
      fi
      if [[ -n "$content" ]]; then
        found=1
        while IFS= read -r line; do
          printf '%s: %s\n' "$pane_label" "$line"
        done <<< "$content"
      fi
    done < <(find "$dir" -maxdepth 2 -name '*.log' \
      -not -name '*.log.1' -type f 2>/dev/null | sort)
    [[ $found -eq 0 ]] && { echo "tsm log grep: no matches found" >&2; exit 1; }
    return 0
  fi

  local resolved
  resolved=$(resolve_pane_target "$target") || exit 1
  local file
  file=$(log_file_for "$resolved") || exit 1
  if [[ ! -f "$file" ]]; then
    echo "tsm log grep: no log file for $resolved ($file)" >&2
    exit 1
  fi
  if $plain; then
    sed -E $'s/\x1b\\[[0-9;?]*[a-zA-Z]//g; s/\x1b\\][^\x07]*\x07//g' "$file" \
      | grep -- "$pattern" || [[ $? -eq 1 ]]
  else
    grep -- "$pattern" "$file" || [[ $? -eq 1 ]]
  fi
}

do_log_clean() {
  local arg="${1:-}"
  local dir
  dir=$(logs_dir)
  case "$arg" in
    --all)
      [[ -d "$dir" ]] && rm -rf "$dir"/*.log "$dir"/*.log.1 "$dir"/*/*.log "$dir"/*/*.log.1 2>/dev/null
      echo "Cleaned all logs under $dir"
      ;;
    "")
      in_tmux || { echo "tsm log clean: specify a session or use --all." >&2; exit 1; }
      local session
      session=$(current_session)
      rm -rf "$dir/$session"
      echo "Cleaned: $dir/$session"
      ;;
    *)
      rm -rf "$dir/$arg"
      echo "Cleaned: $dir/$arg"
      ;;
  esac
}

do_save_list() {
  local dir
  dir="$(sessions_dir)"
  if [[ ! -d "$dir" ]]; then
    echo "No saved configs."
    return 0
  fi
  local has_yq=false
  command -v yq &>/dev/null && has_yq=true
  local any=false
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    local name session_name created windows panes running
    name=$(basename "$file" .yaml)
    if $has_yq; then
      session_name=$(yq -r '.name // ""' "$file" 2>/dev/null)
      [[ -z "$session_name" ]] && session_name="$name"
      created=$(yq -r '.created_at // "unknown"' "$file" 2>/dev/null)
      windows=$(yq -r '.windows | length' "$file" 2>/dev/null)
      panes=$(yq -r '[.windows[].panes | length] | add // 0' "$file" 2>/dev/null)
    else
      session_name="$name"
    fi
    running=""
    tmux has-session -t "=$session_name" 2>/dev/null && running=" ●"
    if $has_yq; then
      printf "  %-20s  %s  (%s window(s), %s pane(s))%s\n" "$name" "$created" "$windows" "$panes" "$running"
    else
      printf "  %s%s\n" "$name" "$running"
    fi
    any=true
  done < <(find "$dir" -maxdepth 1 -name '*.yaml' -type f | sort)
  $any || echo "No saved configs."
}

do_save_delete() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    local dir
    dir="$(sessions_dir)"
    local configs
    configs=$(find "$dir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null \
      | sed -e 's|.*/||' -e 's|\.yaml$||')
    if [[ -z "$configs" ]]; then
      echo "tsm save: no saved configs to delete." >&2; return 1
    fi
    name=$(echo "$configs" | fzf --ansi --reverse --no-sort \
      --prompt="delete saved config > ") || return 0
    [[ -z "$name" ]] && return 0
  fi
  local file
  file="$(sessions_dir)/$(config_name_for "$name").yaml"
  if [[ ! -f "$file" ]]; then
    echo "tsm save: config not found: $file" >&2; exit 1
  fi
  printf "Delete saved config '%s'? [y/N] " "$name"
  read -r confirm
  if [[ "$confirm" =~ ^[yY]$ ]]; then
    rm "$file" && echo "Deleted: $file"
  else
    echo "Cancelled."
  fi
}

do_save_all() {
  local sessions saved=0 failed=0
  sessions=$(tmux list-sessions -F '#{session_name}' 2>/dev/null)
  if [[ -z "$sessions" ]]; then
    echo "tsm save --all: no running sessions." >&2
    return 1
  fi
  while IFS= read -r s; do
    if do_save "$s" --quiet 2>/dev/null; then
      (( saved++ )) || true
    else
      (( failed++ )) || true
      echo "tsm save --all: failed to save '$s'" >&2
    fi
  done <<< "$sessions"
  echo "tsm: saved $saved session(s)${failed:+ ($failed failed)}."
}

do_restore_all() {
  local with_commands=false
  [[ "${1:-}" == "--with-commands" ]] && with_commands=true

  local dir
  dir="$(sessions_dir)"
  local files=("$dir"/*.yaml)
  if [[ ! -e "${files[0]}" ]]; then
    echo "tsm restore --all: no saved configs found in $dir" >&2
    return 1
  fi

  local restored=0 skipped=0 failed=0
  for file in "${files[@]}"; do
    local name
    name=$(basename "$file" .yaml)
    local restore_args=("--no-attach" "$name")
    $with_commands && restore_args=("--no-attach" "--with-commands" "$name")
    if ( do_restore "${restore_args[@]}" 2>/dev/null ); then
      (( restored++ )) || true
    else
      (( failed++ )) || true
      echo "tsm restore --all: failed to restore '$name'" >&2
    fi
  done
  echo "tsm: restored $restored session(s)${failed:+ ($failed failed)}."
}

# ─── session groups (workspaces) ─────────────────────────────────────────────

group_file_for() { echo "$(groups_dir)/$(config_name_for "$1").yaml"; }

do_group_save() {
  local name="${1:-}"
  shift || true
  if [[ -z "$name" ]]; then
    printf "Group name: "
    read -r name
    [[ -z "$name" ]] && { echo "Aborted."; return 1; }
  fi

  local members=("$@")
  if [[ ${#members[@]} -eq 0 ]]; then
    local picked
    picked=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | \
      fzf --ansi --reverse --no-sort --multi \
          --prompt="add to group '$name' (TAB to select) > ") || return 0
    [[ -z "$picked" ]] && { echo "No sessions selected. Aborted."; return 1; }
    while IFS= read -r s; do [[ -n "$s" ]] && members+=("$s"); done <<< "$picked"
  fi

  # Snapshot each member's current layout so the group is restorable on its own.
  local saved=() s
  for s in "${members[@]}"; do
    if ! tmux has-session -t "=$s" 2>/dev/null; then
      echo "tsm group save: session '$s' not running — skipped." >&2
      continue
    fi
    if do_save "$s" --quiet 2>/dev/null; then
      saved+=("$s")
    else
      echo "tsm group save: failed to snapshot '$s' — skipped." >&2
    fi
  done

  if [[ ${#saved[@]} -eq 0 ]]; then
    echo "tsm group save: no sessions saved; group not created." >&2
    return 1
  fi

  local dir
  dir="$(groups_dir)"
  mkdir -p "$dir"
  local out
  out="$(group_file_for "$name")"

  if [[ -f "$out" ]]; then
    printf "Group '%s' already exists. Overwrite? [y/N] " "$name"
    read -r confirm
    [[ ! "$confirm" =~ ^[yY]$ ]] && { echo "Cancelled."; return 0; }
  fi

  {
    printf "name: %s\n" "$(yaml_squote "$name")"
    printf "created_at: %s\n" "$(yaml_squote "$(date -u +%Y-%m-%dT%H:%M:%SZ)")"
    printf "sessions:\n"
    for s in "${saved[@]}"; do
      printf "  - %s\n" "$(yaml_squote "$s")"
    done
  } > "$out"

  echo "Saved group '$name' (${#saved[@]} session(s)): ${saved[*]}"
}

do_group_restore() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    name="$(pick_group)" || return 0
    [[ -z "$name" ]] && return 0
  fi

  local file
  file="$(group_file_for "$name")"
  if [[ ! -f "$file" ]]; then
    echo "tsm group restore: group not found: $file" >&2
    return 1
  fi

  require_yq

  local members
  members=$(yq -r '.sessions[]' "$file" 2>/dev/null)
  if [[ -z "$members" ]]; then
    echo "tsm group restore: group '$name' has no sessions." >&2
    return 1
  fi

  local restored=0 failed=0 s
  while IFS= read -r s; do
    [[ -z "$s" ]] && continue
    if ( do_restore --no-attach "$s" 2>/dev/null ); then
      (( restored++ )) || true
    else
      (( failed++ )) || true
      echo "tsm group restore: failed to restore '$s' (missing config or already running)" >&2
    fi
  done <<< "$members"

  echo "tsm: restored group '$name' — $restored session(s)${failed:+ ($failed failed)}."
}

do_group_list() {
  local dir
  dir="$(groups_dir)"
  if [[ ! -d "$dir" ]]; then
    echo "No saved groups."
    return 0
  fi
  local has_yq=false
  command -v yq &>/dev/null && has_yq=true
  local any=false
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    local name count
    name=$(basename "$file" .yaml)
    if $has_yq; then
      count=$(yq -r '.sessions | length' "$file" 2>/dev/null)
      local members
      members=$(yq -r '.sessions | join(", ")' "$file" 2>/dev/null)
      printf "  %-20s  %s session(s): %s\n" "$name" "${count:-0}" "$members"
    else
      printf "  %s\n" "$name"
    fi
    any=true
  done < <(find "$dir" -maxdepth 1 -name '*.yaml' -type f | sort)
  $any || echo "No saved groups."
}

do_group_delete() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    name="$(pick_group)" || return 0
    [[ -z "$name" ]] && return 0
  fi
  local file
  file="$(group_file_for "$name")"
  if [[ ! -f "$file" ]]; then
    echo "tsm group: group not found: $file" >&2
    return 1
  fi
  printf "Delete group '%s'? [y/N] " "$name"
  read -r confirm
  if [[ "$confirm" =~ ^[yY]$ ]]; then
    rm -f "$file" && echo "Deleted: $file"
  else
    echo "Cancelled."
  fi
}

pick_group() {
  local dir
  dir="$(groups_dir)"
  if [[ ! -d "$dir" ]]; then
    echo "tsm group: no saved groups (directory $dir does not exist)." >&2
    return 1
  fi
  local groups
  groups=$(find "$dir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null \
    | sed -e 's|.*/||' -e 's|\.yaml$||')
  if [[ -z "$groups" ]]; then
    echo "tsm group: no saved groups in $dir." >&2
    return 1
  fi
  echo "$groups" | fzf --ansi --reverse --no-sort --prompt="group > " \
    --bind "q:abort,esc:abort"
}

do_save() {
  local target="${1:-}" quiet=false
  [[ "${2:-}" == "--quiet" ]] && quiet=true

  if [[ -z "$target" ]]; then
    if ! in_tmux; then
      echo "tsm save: must be inside tmux or pass a session name." >&2
      return 1
    fi
    target="$(current_session)"
  fi

  if ! tmux has-session -t "=$target" 2>/dev/null; then
    echo "tsm save: session '$target' not found." >&2
    return 1
  fi

  local dir
  dir="$(sessions_dir)"
  mkdir -p "$dir"
  local out="$dir/$(config_name_for "$target").yaml"

  if [[ -f "$out" ]] && ! $quiet; then
    local stored_name=""
    command -v yq &>/dev/null && stored_name=$(yq -r '.name // ""' "$out" 2>/dev/null)
    if [[ -n "$stored_name" && "$stored_name" != "$target" ]]; then
      printf "Config '%s' belongs to session '%s'. Overwrite with '%s'? [y/N] " \
        "$(basename "$out" .yaml)" "$stored_name" "$target"
    else
      printf "Config '%s' already exists. Overwrite? [y/N] " "$(basename "$out" .yaml)"
    fi
    read -r confirm
    [[ ! "$confirm" =~ ^[yY]$ ]] && { echo "Cancelled."; return 0; }
  fi

  {
    printf "name: %s\n" "$(yaml_squote "$target")"
    printf "created_at: %s\n" "$(yaml_squote "$(date -u +%Y-%m-%dT%H:%M:%SZ)")"
    printf "windows:\n"

    local windows
    windows=$(tmux list-windows -t "$target" \
      -F '#{window_index}|#{window_name}|#{window_active}|#{window_layout}')

    while IFS='|' read -r w_idx w_name w_active w_layout; do
      printf "  - index: %s\n" "$w_idx"
      printf "    name: %s\n" "$(yaml_squote "$w_name")"
      printf "    active: %s\n" "$(bool_from_flag "$w_active")"
      printf "    layout: %s\n" "$(yaml_squote "$w_layout")"
      printf "    panes:\n"

      local panes
      panes=$(tmux list-panes -t "$target:$w_idx" \
        -F '#{pane_index}|#{pane_active}|#{pane_current_path}|#{pane_current_command}')

      while IFS='|' read -r p_idx p_active p_cwd p_cmd; do
        printf "      - index: %s\n" "$p_idx"
        printf "        active: %s\n" "$(bool_from_flag "$p_active")"
        printf "        cwd: %s\n" "$(yaml_squote "$p_cwd")"
        printf "        command: %s\n" "$(yaml_squote "$p_cmd")"
        printf "        log_file: %s\n" "$(yaml_squote "$(pane_log_path "$target" "$w_idx" "$p_idx")")"
      done <<< "$panes"
    done <<< "$windows"
  } > "$out"

  # Snapshot scrollback of panes not currently being logged
  local snap_panes
  snap_panes=$(tmux list-panes -s -t "=$target" \
    -F '#{pane_pipe} #{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)
  while IFS=' ' read -r piped p; do
    [[ -z "$p" || "$piped" == "1" ]] && continue
    local snap_file
    snap_file=$(log_file_for "$p") || continue
    mkdir -p "$(dirname "$snap_file")"
    tmux capture-pane -t "$p" -p -S - > "$snap_file" 2>/dev/null || true
  done <<< "$snap_panes"

  $quiet || echo "Saved: $out"
}

# ─── templates ───────────────────────────────────────────────────────────────

templates_dir() { echo "${XDG_CONFIG_HOME:-$HOME/.config}/tsm/templates"; }

_builtin_preview() {
  local name="$1"
  case "$name" in
    simple)
      printf '  [built-in]\n'
      printf '  ┌─────────────┐\n'
      printf '  │             │\n'
      printf '  │      0      │\n'
      printf '  │             │\n'
      printf '  └─────────────┘\n'
      printf '  1 window · 1 pane\n'
      ;;
    split-h)
      printf '  [built-in]\n'
      printf '  ┌──────┬──────┐\n'
      printf '  │      │      │\n'
      printf '  │  0   │  1   │\n'
      printf '  │      │      │\n'
      printf '  └──────┴──────┘\n'
      printf '  1 window · 2 panes (left | right)\n'
      ;;
    split-v)
      printf '  [built-in]\n'
      printf '  ┌─────────────┐\n'
      printf '  │      0      │\n'
      printf '  ├─────────────┤\n'
      printf '  │      1      │\n'
      printf '  └─────────────┘\n'
      printf '  1 window · 2 panes (top / bottom)\n'
      ;;
    main-h)
      printf '  [built-in]\n'
      printf '  ┌──────┬──────┐\n'
      printf '  │  0   │  2   │\n'
      printf '  ├──────┴──────┤\n'
      printf '  │      1      │\n'
      printf '  └─────────────┘\n'
      printf '  1 window · 3 panes (2 top + 1 bottom)\n'
      ;;
    main-v)
      printf '  [built-in]\n'
      printf '  ┌──────┬──────┐\n'
      printf '  │      │  1   │\n'
      printf '  │  0   ├──────┤\n'
      printf '  │      │  2   │\n'
      printf '  └──────┴──────┘\n'
      printf '  1 window · 3 panes (1 left + 2 right)\n'
      ;;
    *)
      printf '  (unknown built-in template)\n'
      ;;
  esac
}

_apply_builtin_panes() {
  local session="$1" tname="$2"
  local win_idx
  win_idx=$(tmux display-message -t "$session:" -p '#{window_index}')
  local w="$session:$win_idx"
  case "$tname" in
    simple) : ;;
    split-h)
      tmux split-window -h -t "$w"
      tmux select-layout -t "$w" even-horizontal
      ;;
    split-v)
      tmux split-window -v -t "$w"
      tmux select-layout -t "$w" even-vertical
      ;;
    main-h)
      # pane .0 top-left, pane .1 bottom (full width), pane .2 top-right
      tmux split-window -v -t "$w"
      tmux split-window -h -t "$w.0"
      tmux select-pane -t "$w.0" 2>/dev/null || true
      ;;
    main-v)
      # pane .0 left, pane .1 top-right, pane .2 bottom-right
      tmux split-window -h -t "$w"
      tmux split-window -v -t "$w.1"
      tmux select-layout -t "$w" main-vertical
      ;;
  esac
}

pick_template() {
  local tdir
  tdir="$(templates_dir)"
  local self_q
  printf -v self_q '%q' "$0"

  local picked
  picked=$(
    {
      printf 'builtin/%s\n' simple split-h split-v main-h main-v
      if [[ -d "$tdir" ]]; then
        find "$tdir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null \
          | sed -e 's|.*/||' -e 's|\.yaml$||'
      fi
    } | fzf --ansi --reverse --no-sort \
        --prompt="template > " \
        --preview="$self_q template __preview {}" \
        --preview-window='right:45%:wrap' \
        --bind "j:down,k:up" \
        --bind "q:abort,esc:abort"
  ) || return 1
  [[ -z "$picked" ]] && return 1
  echo "$picked"
}

do_template_preview() {
  local name="${1:-}"
  if [[ "$name" == builtin/* ]]; then
    _builtin_preview "${name#builtin/}"
    return 0
  fi
  local file
  file="$(templates_dir)/$(config_name_for "$name").yaml"
  if [[ ! -f "$file" ]]; then
    printf '  (template not found)\n'
    return 0
  fi
  if command -v yq &>/dev/null; then
    yq -r '.windows[] | "  window \(.index): \(.name)  (\(.panes | length) pane(s))"' \
      "$file" 2>/dev/null | grep . || cat "$file" 2>/dev/null
  else
    cat "$file"
  fi
}

do_template_apply() {
  local name="${1:-}" session_name
  if [[ -z "$name" ]]; then
    name="$(pick_template)" || return 1
  fi

  printf "New session name: "
  read -r session_name
  if [[ -z "$session_name" ]]; then
    echo "Aborted."
    return 1
  fi

  if tmux has-session -t "=$session_name" 2>/dev/null; then
    echo "Session '$session_name' already exists. Attaching." >&2
    do_attach "$session_name"
    return 0
  fi

  if [[ "$name" == builtin/* ]]; then
    local tname="${name#builtin/}"
    tmux new-session -d -s "$session_name" -n main
    _apply_builtin_panes "$session_name" "$tname"
    do_attach "$session_name"
    return 0
  fi

  require_yq
  local file
  file="$(templates_dir)/$(config_name_for "$name").yaml"
  if [[ ! -f "$file" ]]; then
    echo "tsm template: not found: $file" >&2; return 1
  fi

  local windows_data
  windows_data=$(yq -r \
    '.windows | to_entries[] | "\(.key)|\(.value.name)|\(.value.layout)"' "$file")

  local first=true
  while IFS='|' read -r wi w_name w_layout; do
    local n_panes
    n_panes=$(yq -r ".windows[$wi].panes | length" "$file")

    if $first; then
      tmux new-session -d -s "$session_name" -n "$w_name"
      first=false
    else
      tmux new-window -t "$session_name" -n "$w_name"
    fi

    local current_idx
    current_idx=$(tmux display-message -t "$session_name:" -p '#{window_index}')

    local pi
    for ((pi=1; pi<n_panes; pi++)); do
      tmux split-window -t "$session_name:$current_idx"
    done

    tmux select-layout -t "$session_name:$current_idx" "$w_layout" 2>/dev/null \
      || { tmux select-layout -t "$session_name:$current_idx" even-horizontal 2>/dev/null || true
           echo "tsm template: warning — layout mismatch for window '$w_name'; applied even-horizontal" >&2; }
  done <<< "$windows_data"

  do_attach "$session_name"
}

do_template_save() {
  local name="${1:-}"
  if ! in_tmux; then
    echo "tsm template save: must be inside tmux." >&2; return 1
  fi
  local target
  target="$(current_session)"

  if [[ -z "$name" ]]; then
    printf "Template name: "
    read -r name
    [[ -z "$name" ]] && { echo "Aborted."; return 0; }
  fi

  local dir
  dir="$(templates_dir)"
  mkdir -p "$dir"
  local out="$dir/$(config_name_for "$name").yaml"

  if [[ -f "$out" ]]; then
    printf "Template '%s' already exists. Overwrite? [y/N] " "$name"
    read -r confirm
    [[ ! "$confirm" =~ ^[yY]$ ]] && { echo "Cancelled."; return 0; }
  fi

  local tmp
  tmp=$(mktemp "${dir}/.tsm_template.XXXXXX")

  {
    printf "name: %s\n" "$(yaml_squote "$name")"
    printf "created_at: %s\n" "$(yaml_squote "$(date -u +%Y-%m-%dT%H:%M:%SZ)")"
    printf "windows:\n"

    local windows
    windows=$(tmux list-windows -t "$target" \
      -F '#{window_index}|#{window_name}|#{window_active}|#{window_layout}')

    while IFS='|' read -r w_idx w_name w_active w_layout; do
      printf "  - index: %s\n" "$w_idx"
      printf "    name: %s\n" "$(yaml_squote "$w_name")"
      printf "    active: %s\n" "$(bool_from_flag "$w_active")"
      printf "    layout: %s\n" "$(yaml_squote "$w_layout")"
      printf "    panes:\n"
      local n_panes
      n_panes=$(tmux list-panes -t "$target:$w_idx" | wc -l | tr -d ' ')
      local pi
      for ((pi=0; pi<n_panes; pi++)); do
        printf "      - index: %s\n" "$pi"
      done
    done <<< "$windows"
  } > "$tmp" && mv "$tmp" "$out" || { rm -f "$tmp"; return 1; }

  echo "Template saved: $out"
}

do_template_delete() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    local tdir
    tdir="$(templates_dir)"
    if [[ ! -d "$tdir" ]]; then
      echo "tsm template: no user templates." >&2; return 1
    fi
    local configs
    configs=$(find "$tdir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null \
      | sed -e 's|.*/||' -e 's|\.yaml$||')
    if [[ -z "$configs" ]]; then
      echo "tsm template: no user templates." >&2; return 1
    fi
    name=$(echo "$configs" | fzf --ansi --reverse --no-sort \
      --prompt="delete template > ") || return 0
    [[ -z "$name" ]] && return 0
  fi

  case "$name" in
    builtin/*|simple|split-h|split-v|main-h|main-v)
      echo "tsm template: cannot delete built-in templates." >&2; return 1 ;;
  esac

  local file
  file="$(templates_dir)/$(config_name_for "$name").yaml"
  if [[ ! -f "$file" ]]; then
    echo "tsm template: not found: $file" >&2; return 1
  fi

  printf "Delete template '%s'? [y/N] " "$name"
  read -r confirm
  [[ ! "$confirm" =~ ^[yY]$ ]] && { echo "Cancelled."; return 0; }
  rm -f "$file"
  echo "Deleted: $file"
}

do_template_list() {
  printf 'Built-in:\n'
  printf '  %s\n' simple split-h split-v main-h main-v
  local tdir
  tdir="$(templates_dir)"
  if [[ -d "$tdir" ]]; then
    local user_templates
    user_templates=$(find "$tdir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null \
      | sed -e 's|.*/||' -e 's|\.yaml$||')
    if [[ -n "$user_templates" ]]; then
      printf 'User:\n'
      while IFS= read -r t; do
        printf '  %s\n' "$t"
      done <<< "$user_templates"
    fi
  fi
}

do_main_preview() {
  local name="${1:-}"
  local pane_nav_file="${2:-}"
  if [[ -z "$name" || "$name" == "__create__" ]]; then
    printf '  Create a new session\n'
    return 0
  fi
  if tmux has-session -t "=$name" 2>/dev/null; then
    # Collect all panes across all windows: "win_idx.pane_idx win_name"
    local pane_list total_panes pane_idx
    pane_list=$(tmux list-panes -s -t "=$name" \
      -F '#{window_index}.#{pane_index} #{window_name}' 2>/dev/null)
    total_panes=$(printf '%s\n' "$pane_list" | wc -l | tr -d ' ')
    [[ -z "$pane_list" || "$total_panes" -eq 0 ]] && { printf '  (no panes)\n'; return 0; }

    pane_idx=0
    if [[ -n "$pane_nav_file" && -f "$pane_nav_file" ]]; then
      local _raw
      _raw=$(cat "$pane_nav_file" 2>/dev/null)
      [[ "$_raw" =~ ^[0-9]+$ ]] && pane_idx="$_raw"
    fi
    [[ "$pane_idx" -ge "$total_panes" ]] && pane_idx=$(( total_panes - 1 ))

    local pane_line pane_ref win_name
    pane_line=$(printf '%s\n' "$pane_list" | sed -n "$(( pane_idx + 1 ))p")
    pane_ref="${pane_line%% *}"
    win_name="${pane_line#* }"

    local logged_panes
    logged_panes=$(tmux list-panes -s -t "=$name" \
      -F '#{pane_pipe} #{window_index}.#{pane_index}' 2>/dev/null | \
      awk '$1==1{printf "%s%s", sep, $2; sep=","} END{if(NR>0)print ""}')
    if [[ -n "$logged_panes" ]]; then
      printf '\033[32m  ⏺ logging: %s\033[0m\n' "$logged_panes"
    else
      printf '\033[2m  ○ not logging\033[0m\n'
    fi

    printf '\033[2m  [%s] · pane %d/%d  < prev · next >\033[0m\n' \
      "$win_name" "$(( pane_idx + 1 ))" "$total_panes"
    tmux capture-pane -p -e -t "$name:$pane_ref" 2>/dev/null
  else
    printf '  \033[2m(not running)\033[0m\n'
    if command -v yq &>/dev/null; then
      local file
      file="$(sessions_dir)/$(config_name_for "$name").yaml"
      if [[ -f "$file" ]]; then
        local desc
        desc=$(yq -r '.description // ""' "$file" 2>/dev/null)
        [[ -n "$desc" ]] && printf '\n  %s\n' "$desc"
        printf '\n'
        yq -r '.windows[] | "  \(.index): \(.name)  (\(.panes|length) pane(s))"' "$file" 2>/dev/null
      fi
    fi
  fi
  return 0
}

# ─── main fzf menu ───────────────────────────────────────────────────────────

main() {
  local action_file pane_nav_file
  action_file="$(mktemp /tmp/tsm_action.XXXXXX)"
  pane_nav_file="$(mktemp /tmp/tsm_pane_nav.XXXXXX)"
  printf '0' > "$pane_nav_file"
  trap 'rm -f "$action_file" "$pane_nav_file"' RETURN

  local create_token="__create__"
  local header
  header=$'↑↓/jk:move  ↵:attach  d:delete  n:new  E:detach  q/ESC:quit\nr:rename  s:save  S:save all  R:restore-saved  l:log-toggle  t:template  1-9:attach nth\n[/]:preview size  </>:prev/next pane'

  local self_q
  printf -v self_q '%q' "$(command -v "$0" 2>/dev/null || printf '%s' "$0")"

  # Session list: field1=raw-name (for {1} bindings), field2=display string (shown via --with-nth=2)
  # First line of output is the column header (used with --header-lines=1).
  local sessions_fmt
  sessions_fmt=$(tmux list-sessions \
    -F $'#{session_name}\t#{session_windows}\t#{session_created}' 2>/dev/null | \
    awk -F'\t' -v now="$(date +%s)" '{
      secs = now - $3
      if (secs < 60)         { age = secs "s" }
      else if (secs < 3600)  { age = int(secs/60) "m" }
      else if (secs < 86400) { age = int(secs/3600) "h " int((secs%3600)/60) "m" }
      else                   { age = int(secs/86400) "d " int((secs%86400)/3600) "h" }
      names[NR] = $1; wins[NR] = $2; ages[NR] = age
      if (length($1) > maxlen) maxlen = length($1)
      total = NR
    }
    END {
      if (total == 0) exit
      printf "\t\033[2m    %-" maxlen "s  Info\033[0m\n", "Session"
      for (i = 1; i <= total; i++) {
        num = (i <= 9) ? i : " "
        printf "%s\t %-1s  %-" maxlen "s  %sw · %s\n", names[i], num, names[i], wins[i], ages[i]
      }
    }') || sessions_fmt=""

  local num_binds=()
  local _i
  for _i in {1..9}; do
    num_binds+=("--bind" "${_i}:execute-silent({ printf 'attach:'; tmux list-sessions -F '#{session_name}' 2>/dev/null | sed -n '${_i}p'; } > '$action_file')+abort")
  done

  local fzf_header_lines=()
  [[ -n "$sessions_fmt" ]] && fzf_header_lines=("--header-lines=1")

  local selected
  selected=$(
    {
      [[ -n "$sessions_fmt" ]] && printf '%s\n' "$sessions_fmt"
      printf '%s\t    [+] Create new session\n' "$create_token"
    } | fzf \
        --ansi --reverse --no-sort \
        --delimiter=$'\t' \
        --with-nth=2 \
        "${fzf_header_lines[@]}" \
        --prompt="tmux session > " \
        --header="$header" \
        --preview="$self_q __main_preview {1} '$pane_nav_file'" \
        --preview-window='right:50%:nowrap' \
        --bind "every(1):refresh-preview" \
        --bind "focus:execute-silent(printf '0' > '$pane_nav_file')+refresh-preview" \
        --bind "<:execute-silent(idx=\$(cat '$pane_nav_file' 2>/dev/null || echo 0); [ \"\$idx\" -gt 0 ] && printf '%s' \$(( idx - 1 )) > '$pane_nav_file' || true)+refresh-preview" \
        --bind ">:execute-silent(idx=\$(cat '$pane_nav_file' 2>/dev/null || echo 0); printf '%s' \$(( idx + 1 )) > '$pane_nav_file')+refresh-preview" \
        --bind "enter:accept" \
        --bind "space:accept" \
        --bind "j:down,k:up" \
        --bind "q:abort,esc:abort" \
        --bind "[:change-preview-window(70%:nowrap|50%:nowrap|30%:nowrap)" \
        --bind "]:change-preview-window(30%:nowrap|50%:nowrap|70%:nowrap)" \
        --bind "d:execute(printf '\n  \033[1;31m⚠\033[0m  Delete \033[1m{1}\033[0m? [y/N]  '; read -r _a < /dev/tty; [[ \$_a == [yY] ]] && printf 'delete:%s' {1} > '$action_file' || printf 'cancel' > '$action_file')+abort" \
        --bind "n:execute-silent(printf 'new' > '$action_file')+abort" \
        --bind "N:execute-silent(printf 'new' > '$action_file')+abort" \
        --bind "r:execute-silent({ printf 'rename:'; printf '%s' {1}; } > '$action_file')+abort" \
        --bind "s:execute-silent({ printf 'save:'; printf '%s' {1}; } > '$action_file')+abort" \
        --bind "S:execute(_n=\$(tmux list-sessions -F '#{session_name}' 2>/dev/null | wc -l | tr -d ' '); printf '\n  Save all %s session(s)? [y/N]  ' \"\$_n\"; read -r _a < /dev/tty; [[ \$_a == [yY] ]] && printf 'save-all' > '$action_file' || printf 'cancel' > '$action_file')+abort" \
        --bind "R:execute-silent(printf 'restore' > '$action_file')+abort" \
        --bind "E:execute-silent(printf 'detach' > '$action_file')+abort" \
        --bind "l:execute-silent($self_q log toggle '{1}' 2>/dev/null)+refresh-preview" \
        --bind "t:execute-silent(printf 'template' > '$action_file')+abort" \
        "${num_binds[@]}" \
      || true
  )
  selected="${selected%%$'\t'*}"

  local action=""
  [[ -s "$action_file" ]] && action="$(<"$action_file")"

  # resolve action from enter-select on create token
  [[ "$selected" == "$create_token" ]] && action="new"

  case "$action" in
    delete:*)
      local target="${action#delete:}"
      [[ "$target" == "$create_token" ]] && { main; return; }
      do_delete "$target"
      ;;
    rename:*)
      local target="${action#rename:}"
      [[ "$target" == "$create_token" ]] && { main; return; }
      do_rename "$target"
      ;;
    save:*)
      local target="${action#save:}"
      [[ "$target" == "$create_token" ]] && { main; return; }
      do_save "$target" || true
      sleep 0.4
      main
      ;;
    save-all)
      do_save_all || true
      sleep 1
      main
      ;;
    cancel) main ;;

    restore)   do_restore ;;
    template)
      do_template_apply || { sleep 0.3; main; return; }
      ;;
    new)       do_new ;;
    detach)    do_detach ;;
    attach:*)
      local target="${action#attach:}"
      if [[ -n "$target" ]]; then
        do_attach "$target"
      else
        main
      fi
      ;;
    "")
      # fzf aborted with no action file written (q / ESC) — just exit
      [[ -z "$selected" ]] && return 0
      do_attach "$selected"
      ;;
  esac
}

do_doctor() {
  local ok=0 warn=0 fail=0
  _ok()   { printf '  \e[32m✓\e[0m %s\n' "$1"; (( ok++   )) || true; }
  _warn() { printf '  \e[33m!\e[0m %s\n' "$1"; (( warn++ )) || true; }
  _fail() { printf '  \e[31m✗\e[0m %s\n' "$1"; (( fail++ )) || true; }

  printf '\n\e[1mDependencies\e[0m\n'

  # tmux
  if command -v tmux &>/dev/null; then
    local tv
    tv=$(tmux -V 2>/dev/null | awk '{print $2}')
    _ok "tmux $tv"
  else
    _fail "tmux not found (required)"
  fi

  # fzf
  if command -v fzf &>/dev/null; then
    local fv
    fv=$(fzf --version 2>/dev/null | awk '{print $1}')
    _ok "fzf $fv"
  else
    _fail "fzf not found (required)"
  fi

  # yq
  if command -v yq &>/dev/null; then
    local yv
    yv=$(yq --version 2>/dev/null | awk '{print $NF}')
    _ok "yq $yv (optional — needed for save/restore)"
  else
    _warn "yq not found (optional — needed for tsm save/restore)"
  fi

  printf '\n\e[1mConfig\e[0m\n'

  local cfg_file
  cfg_file="$(tsm_self_config_path)"
  if [[ ! -f "$cfg_file" ]]; then
    _ok "no config file (using defaults)"
  elif ! command -v yq &>/dev/null; then
    _warn "config file exists at $cfg_file but yq is not installed (cannot validate)"
  else
    local cfg_ok=true
    local val
    val=$(yq -r '.log_max_bytes // ""' "$cfg_file" 2>/dev/null)
    if [[ -n "$val" && ! "$val" =~ ^[0-9]+$ ]]; then
      _fail "config: log_max_bytes must be an integer (got: $val)"
      cfg_ok=false
    fi
    val=$(yq -r '.auto_log // ""' "$cfg_file" 2>/dev/null)
    if [[ -n "$val" && "$val" != "true" && "$val" != "false" ]]; then
      _fail "config: auto_log must be true or false (got: $val)"
      cfg_ok=false
    fi
    local sd
    sd=$(yq -r '.sessions_dir // ""' "$cfg_file" 2>/dev/null)
    sd="${sd/#\~/$HOME}"
    [[ -n "$sd" && ! -d "$sd" ]] && _warn "config: sessions_dir '$sd' does not exist"
    local ld
    ld=$(yq -r '.logs_dir // ""' "$cfg_file" 2>/dev/null)
    ld="${ld/#\~/$HOME}"
    [[ -n "$ld" && ! -d "$ld" ]] && _warn "config: logs_dir '$ld' does not exist (created on first use)"
    $cfg_ok && _ok "config valid ($cfg_file)"
  fi

  printf '\n\e[1mDisk usage\e[0m\n'

  local sess_dir log_dir
  sess_dir="$(sessions_dir)"
  log_dir="$(logs_dir)"

  if [[ -d "$sess_dir" ]]; then
    local n_saved
    n_saved=$(find "$sess_dir" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null | wc -l | tr -d ' ')
    local sess_size
    sess_size=$(du -sh "$sess_dir" 2>/dev/null | awk '{print $1}')
    _ok "sessions: $n_saved saved configs, $sess_size ($sess_dir)"
  else
    _ok "sessions: no saved configs ($sess_dir)"
  fi

  if [[ -d "$log_dir" ]]; then
    local log_size n_logs
    log_size=$(du -sh "$log_dir" 2>/dev/null | awk '{print $1}')
    n_logs=$(find "$log_dir" -name '*.log' -not -name '*.log.1' -type f 2>/dev/null | wc -l | tr -d ' ')
    _ok "logs: $n_logs log files, $log_size ($log_dir)"
  else
    _ok "logs: no log directory ($log_dir)"
  fi

  printf '\n'
  local total=$(( ok + warn + fail ))
  printf '%d check(s): \e[32m%d ok\e[0m' "$total" "$ok"
  [[ $warn -gt 0 ]] && printf ', \e[33m%d warning(s)\e[0m' "$warn"
  [[ $fail -gt 0 ]] && printf ', \e[31m%d failure(s)\e[0m' "$fail"
  printf '\n\n'
  [[ $fail -gt 0 ]] && return 1 || return 0
}

# ─── CLI ─────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
tsm $VERSION - tmux session manager

Usage: tsm [command]

Commands:
  (none)            Open interactive session picker
  --popup           Open the picker in a tmux popup (tmux >= 3.2, inside tmux)
  --no-popup        Open the picker full-screen (override the 'popup' config)
  new [name]        Create and attach a new session
  ls                List all sessions
  kill [name]       Kill a session (picker if name omitted)
  kill --all        Kill multiple sessions (fzf multi-select, TAB to select)
  rename <old> <new>  Rename a session
  config [--read]   Read tmux config (default)
  config --edit     Edit tmux config, prompt to reload after
  config --reload   Reload tmux config (must be inside tmux)
  config --tsm      Edit tsm's own config (~/.config/tsm/config.yaml)
  save [name]       Save session layout to ~/.config/tsm/sessions/<name>.yaml
                    (uses current session if name omitted)
  save --list       List saved configs with metadata
  save --delete [name]  Delete a saved config (fzf picker if name omitted)
  restore [name]              Restore a saved session (fzf picker if omitted)
  restore --all               Restore all saved sessions at once
  restore --all --with-commands  Restore all + re-run saved commands
  restore --with-commands [name]
                              Restore layout and re-run saved commands
                              (skips: bash zsh sh fish dash tmux)
  log <action>      Pane output logging (see 'tsm log help')
  template              Open template picker (create new session from template)
  template list         List all templates (built-in + user)
  template apply [name] Create a new session from a template
  template save [name]  Save current session layout as a user template
  template delete [name]Delete a user template
  clone [src] [new] Duplicate a live session's window/pane layout into a new session
  group save <name> [session...]  Save a named set of sessions (a workspace)
  group restore <name>            Restore every session in a group
  group list                      List saved groups and their members
  group delete [name]             Delete a group manifest (member configs kept)
  doctor            Check dependencies, validate config, show disk usage
  version           Show version
  help              Show this help

Keybindings (inside picker):
  ↑↓ / j k    Navigate
  Enter/Space  Attach to session
  d / ⌫       Delete session
  n / N        New session
  r            Rename selected session
  s            Save selected session layout
  R            Restore a saved session (opens picker)
  l            Toggle pane logging for the selected session's active pane
  t            Create new session from a template (opens template picker)
  E            Detach current client
  q / ESC      Quit
EOF
}

# Hot-path subcommands skip config loading: they run on every cursor movement in fzf pickers.
_tsm_cmd_key="${1:-}:${2:-}"
if [[ "$_tsm_cmd_key" != "log:__write" && \
      "$_tsm_cmd_key" != "template:__preview" && \
      "$_tsm_cmd_key" != "restore:__preview" && \
      "${1:-}" != "__main_preview" ]]; then
  load_config
  apply_env_overrides
fi
unset _tsm_cmd_key

case "${1:-}" in
  "")            check_deps; run_picker "" ;;
  --popup)       check_deps; run_picker force-on ;;
  --no-popup)    check_deps; run_picker force-off ;;
  __popup_check) should_use_popup "${2:-}" ;;
  __main_preview) do_main_preview "${2:-}" "${3:-}" ;;
  new)
    check_deps
    if [[ -n "${2:-}" ]]; then
      if tmux has-session -t "=$2" 2>/dev/null; then
        echo "Session '$2' already exists. Attaching." >&2
        do_attach "$2"
      elif in_tmux; then
        tmux new-session -d -s "$2"
        [[ "$_TSM_AUTO_LOG" == "true" ]] && do_log_start "$2" 2>/dev/null || true
        tmux switch-client -t "=$2"
      else
        tmux new-session -s "$2"
      fi
    else
      do_new
    fi
    ;;
  ls|list)  tmux list-sessions 2>/dev/null || echo "No tmux sessions." ;;
  rename)
    check_deps
    if [[ -z "${2:-}" ]] || [[ -z "${3:-}" ]]; then
      echo "Usage: tsm rename <old-name> <new-name>" >&2; exit 1
    fi
    tmux rename-session -t "=$2" "$3" && echo "Renamed '$2' → '$3'"
    ;;
  kill)
    check_deps
    if [[ "${2:-}" == "--all" ]]; then
      pick_kill_multi
    elif [[ -n "${2:-}" ]]; then
      do_kill "$2"
    else
      pick_kill
    fi
    ;;
  config)
    case "${2:---read}" in
      --read)   do_config_read ;;
      --edit)   do_config_edit ;;
      --reload) do_config_reload ;;
      --tsm)    do_config_tsm ;;
      *) echo "tsm config: unknown option '${2}'" >&2; usage >&2; exit 1 ;;
    esac
    ;;
  save)
    case "${2:-}" in
      --list)   do_save_list ;;
      --delete) check_deps; do_save_delete "${3:-}" ;;
      --all)    check_deps; do_save_all ;;
      *)        check_deps; do_save "${2:-}" ;;
    esac
    ;;
  restore)
    case "${2:-}" in
      __preview)     do_restore_preview "${3:-}" ;;
      --all)         check_deps; do_restore_all "${3:-}" ;;
      *)             check_deps; shift; do_restore "$@" ;;
    esac
    ;;
  log)
    case "${2:-}" in
      start)   check_deps; shift 2; do_log_start "$@" ;;
      stop)    check_deps; do_log_stop   "${3:-}" ;;
      toggle)  check_deps; do_log_toggle "${3:-}" ;;
      status)  check_deps; do_log_status ;;
      list)    do_log_list "${3:-}" ;;
      show)    check_deps; shift 2; do_log_show "$@" ;;
      tail)    check_deps; shift 2; do_log_tail "$@" ;;
      grep)    check_deps; shift 2; do_log_grep "$@" ;;
      clean)   do_log_clean "${3:-}" ;;
      __write) do_log_write "${3:-}" "${4:-}" "${5:-}" ;;
      help|"")
        cat <<EOF
tsm log <action>

Actions:
  start [--timestamp] [target|--all|--all-sessions]
                         Start logging (--timestamp prepends [YYYY-MM-DDTHH:MM:SS] to each line)
                         --all-sessions: start on all panes across all sessions (skips already-logging)
  stop  [target|--all|--all-sessions]
                         Stop logging (--all-sessions: stop all logged panes across all sessions)
  status                 Show panes currently being logged
  list  [session]        List log files (optionally filter by session)
  show  [target] [--plain]
                         View log via \$PAGER (--plain strips ANSI escapes)
  tail  [target] [--plain]
                         Follow log in real time (like tail -f)
  grep  [--plain] <pattern> [target]
                         Search within log file (--plain strips ANSI before matching)
  clean [session|--all]  Delete log files

Default target: current pane.
Logs: \$XDG_DATA_HOME/tsm/logs/<session>/<window>.<pane>.log
Size cap: 10 MB by default. Override via config file (log_max_bytes) or \$TSM_LOG_MAX_BYTES.
EOF
        ;;
      *) echo "tsm log: unknown action '${2}'" >&2; exit 1 ;;
    esac
    ;;
  template)
    case "${2:-}" in
      __preview) do_template_preview "${3:-}" ;;
      save)      check_deps; do_template_save "${3:-}" ;;
      apply)     check_deps; do_template_apply "${3:-}" ;;
      delete)    check_deps; do_template_delete "${3:-}" ;;
      list)      do_template_list ;;
      help|"")   check_deps; do_template_apply ;;
      *)         echo "tsm template: unknown subcommand '${2}'" >&2; exit 1 ;;
    esac
    ;;
  clone)    check_deps; shift; do_clone "$@" ;;
  group)
    case "${2:-}" in
      save)    check_deps; shift 2; do_group_save "$@" ;;
      restore) check_deps; do_group_restore "${3:-}" ;;
      list)    do_group_list ;;
      delete)  check_deps; do_group_delete "${3:-}" ;;
      help|"")
        cat <<EOF
tsm group <action> — save/restore a named set of sessions (a workspace)

Actions:
  save <name> [session...]  Snapshot the listed sessions and record them as a group.
                            With no sessions, opens an fzf multi-select (TAB to pick).
  restore <name>            Restore every session in the group (fzf picker if name omitted).
                            Already-running sessions are skipped, not fatal.
  list                      List saved groups and their member sessions.
  delete [name]             Delete a group (fzf picker if name omitted). Member session
                            configs are NOT deleted — only the group manifest.

Groups: \$XDG_CONFIG_HOME/tsm/groups/<name>.yaml
Members are ordinary saved session configs, so each can still be restored individually.
EOF
        ;;
      *) echo "tsm group: unknown action '${2}'" >&2; exit 1 ;;
    esac
    ;;
  doctor)   do_doctor ;;
  version)  echo "tsm $VERSION" ;;
  help|-h|--help) usage ;;
  *)        echo "tsm: unknown command '$1'" >&2; usage >&2; exit 1 ;;
esac
