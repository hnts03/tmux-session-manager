#!/usr/bin/env bash
# Automatically append Signed-off-by if not already present (DCO compliance)

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Skip for merge commits, squash, etc.
[[ "$COMMIT_SOURCE" == "merge" ]] && exit 0

SOB="Signed-off-by: $(git config user.name) <$(git config user.email)>"

if ! grep -qF "$SOB" "$COMMIT_MSG_FILE"; then
  printf "\n%s\n" "$SOB" >> "$COMMIT_MSG_FILE"
fi
